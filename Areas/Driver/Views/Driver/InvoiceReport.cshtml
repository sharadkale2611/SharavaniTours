@model SharavaniTours.Models.InvoiceFilterVM
@using System.Linq

@{
    ViewData["Title"] = "Invoice Reports";
}


<style>
    :root {
        --glass-bg: rgba(30, 41, 59, 0.4);
        --glass-border: rgba(255, 255, 255, 0.08);
        --accent-primary: #3b82f6;
        --accent-success: #10b981;
        --text-main: #f8fafc;
        --text-dim: #94a3b8;
    }

    /* Uniform Form Styling */
    .filter-container {
        background: var(--glass-bg);
        backdrop-filter: blur(20px);
        border-radius: 16px;
        padding: 24px;
        border: 1px solid var(--glass-border);
        margin-bottom: 24px;
    }

    .form-group-custom label {
        color: var(--text-dim);
        font-size: 0.7rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 8px;
        display: block;
    }

    /* Shared Glass Input Style */
    .form-control-glass, .form-select-glass {
        background: rgba(15, 23, 42, 0.6) !important;
        border: 1px solid rgba(255, 255, 255, 0.1) !important;
        color: var(--text-main) !important;
        border-radius: 8px;
        padding: 10px 14px;
        font-size: 0.9rem;
        transition: all 0.2s;
        height: 45px; /* Fixed height for uniformity */
    }

        .form-control-glass:focus {
            border-color: var(--accent-primary) !important;
            box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.2);
            outline: none;
        }

    /* Professional Buttons */
    .btn-filter {
        background: var(--accent-primary);
        color: white;
        border: none;
        border-radius: 8px;
        font-weight: 600;
        height: 45px;
        transition: transform 0.1s, background 0.2s;
    }

        .btn-filter:hover {
            background: #2563eb;
            transform: translateY(-1px);
        }

    .btn-download-outline {
        background: transparent;
        color: var(--accent-success);
        border: 1px solid var(--accent-success);
        border-radius: 8px;
        padding: 8px 16px;
        font-weight: 600;
        font-size: 0.85rem;
        transition: all 0.2s;
    }

        .btn-download-outline:hover {
            background: var(--accent-success);
            color: #fff;
        }

    /* Clean Table Styling - UPDATED */
    .table-glass-clean {
        margin-top: 20px;
        border-collapse: separate;
        border-spacing: 0 10px; /* Space between rows */
        background: transparent !important; /* Ensure table is transparent */
    }

        .table-glass-clean thead th {
            background: transparent !important;
            color: var(--accent-primary);
            font-size: 0.75rem;
            text-transform: uppercase;
            border: none;
            padding: 12px 20px;
        }

        /* Target the cells specifically to kill the white background */
        .table-glass-clean tbody tr td {
            background: rgba(255, 255, 255, 0.05) !important; /* Very subtle dark glass */
            border: none !important;
            color: #f8fafc !important; /* Force off-white text for visibility */
            padding: 16px 20px;
            transition: background 0.3s ease;
        }

        /* Hover effect */
        .table-glass-clean tbody tr:hover td {
            background: rgba(255, 255, 255, 0.12) !important;
            cursor: default;
        }

        /* Rounded corners for the "Floating Row" look */
        .table-glass-clean td:first-child {
            border-radius: 12px 0 0 12px !important;
        }

        .table-glass-clean td:last-child {
            border-radius: 0 12px 12px 0 !important;
        }

    /* ID column emphasis */
    .text-id {
        color: var(--accent-primary);
        font-weight: 700;
    }

    .text-success-bright {
        color: #34d399 !important;
    }
</style>

<div class="mb-4">
    <h2 class="fw-bold text-white mb-1">Invoice Reports</h2>
    <p class="text-muted-light mb-0">Manage and export your fleet financial data.</p>
</div>

<div class="filter-container">
    <form method="get" class="row g-3">
        <div class="col-md-2 form-group-custom">
            <label>From Date</label>
            <input type="date" asp-for="FromDate" class="form-control-glass w-100" />
        </div>

        <div class="col-md-2 form-group-custom">
            <label>To Date</label>
            <input type="date" asp-for="ToDate" class="form-control-glass w-100" />
        </div>

        <div class="col-md-2 form-group-custom">
            <label>Driver</label>
            <select asp-for="DriverId" asp-items="Model.Drivers" class="form-select-glass w-100">
                <option value="">All Drivers</option>
            </select>
        </div>

        <div class="col-md-2 form-group-custom">
            <label>Vehicle</label>
            <select asp-for="VehicleId" asp-items="Model.Vehicles" class="form-select-glass w-100">
                <option value="">All Vehicles</option>
            </select>
        </div>

        <div class="col-md-2 form-group-custom">
            <label>Client User</label>
            <select asp-for="ClientUserId" asp-items="Model.ClientUsers" class="form-select-glass w-100">
                <option value="">All Clients</option>
            </select>
        </div>

        <div class="col-md-2 d-flex align-items-end">
            <button type="submit" class="btn btn-filter w-100">
                <i class="bi bi-funnel-fill me-2"></i>Filter
            </button>
        </div>
    </form>

    <hr style="border-color: rgba(255,255,255,0.05); margin: 20px 0;">

    <form method="get" asp-action="DownloadInvoiceReport">
        <button type="submit" class="btn-download-outline">
            <i class="bi bi-file-earmark-pdf me-1"></i> Export PDF Report
        </button>
    </form>
</div>

@if (Model?.Trips != null && Model.Trips.Any())
{
    <div class="table-responsive">
        <div class="table-responsive">
            <table class="table table-glass-clean">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Date</th>
                        <th>Client</th>
                        <th>Driver</th>
                        <th>Vehicle</th>
                        <th class="text-end">Total Amount</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var trip in Model.Trips)
                    {
                        <tr>
                            <td class="text-id">#@trip.Id</td>
                            <td>@trip.BookedDate.ToString("dd MMM yyyy")</td>
                            <td>@trip.Client?.Name</td>
                            <td>@trip.Driver?.FullName</td>
                            <td>
                                <span class="badge" style="background: rgba(0,0,0,0.3); border: 1px solid rgba(255,255,255,0.1);">
                                    @trip.SentVehicle?.VehicleNo
                                </span>
                            </td>
                            <td class="text-end text-success-bright fw-bold">₹@trip.TotalAmount</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
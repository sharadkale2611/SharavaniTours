@model SharavaniTours.Models.InvoiceFilterVM
@using System.Linq

@{
    ViewData["Title"] = "Invoice Reports";
}

<style>
    .filter-container {
        background: rgba(15, 23, 42, 0.4);
        backdrop-filter: blur(20px);
        border-radius: 16px;
        padding: 20px;
        border: 1px solid rgba(255,255,255,0.08);
        margin-bottom: 20px;
    }

    .form-label {
        color: #94a3b8;
        font-size: 0.75rem;
        font-weight: 600;
        text-transform: uppercase;
        margin-bottom: 6px;
    }

    .form-control-glass {
        background: rgba(15, 23, 42, 0.4);
        border: 1px solid rgba(255,255,255,0.1);
        color: #fff;
        border-radius: 10px;
        padding: 8px 12px;
    }

        .form-control-glass:focus {
            border-color: #3b82f6;
            box-shadow: 0 0 0 3px rgba(59,130,246,0.2);
        }

    .btn-primary-glass {
        background: #3b82f6;
        border: none;
        border-radius: 10px;
        padding: 8px 20px;
        font-weight: 600;
        color: white;
        box-shadow: 0 4px 15px rgba(59,130,246,0.3);
    }

        .btn-primary-glass:hover {
            background: #2563eb;
        }

    .btn-download {
        background: rgba(34,197,94,0.15);
        color: #22c55e;
        border: 1px solid rgba(34,197,94,0.3);
        border-radius: 10px;
        padding: 8px 18px;
        font-weight: 600;
    }

        .btn-download:hover {
            background: #22c55e;
            color: white;
        }

    .table-glass {
        color: #e2e8f0;
        background: rgba(255,255,255,0.03);
        border-radius: 12px;
        overflow: hidden;
    }

        .table-glass th {
            background: rgba(15,23,42,0.8);
            color: #3b82f6;
            font-size: 0.75rem;
            text-transform: uppercase;
            padding: 14px;
        }

        .table-glass td {
            padding: 14px;
            border-top: 1px solid rgba(255,255,255,0.05);
            background: rgb(255 255 255 / 55%);
        }

        .table-glass tr:hover td {
            background: rgb(255 255 255 / 25%);
        }

    .text-muted-light {
        color: #94a3b8;
        font-size: 0.85rem;
    }
</style>

<!-- HEADER -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bold text-white mb-1">Invoice Reports</h2>
        <p class="text-muted-light mb-0">Filter and download trip invoices.</p>
    </div>
</div>

<!-- FILTER -->
<div class="filter-container">
    <form method="get">
        <div class="row g-3 align-items-end">

            <div class="col-md-2">
                <label class="form-label">From</label>
                <input type="date" name="FromDate" value="@Model?.FromDate?.ToString("yyyy-MM-dd")" class="form-control form-control-glass" />
            </div>

            <div class="col-md-2">
                <label class="form-label">To</label>
                <input type="date" name="ToDate" value="@Model?.ToDate?.ToString("yyyy-MM-dd")" class="form-control form-control-glass" />
            </div>

            <div class="col-md-2">
                <label class="form-label">Driver</label>
                <input type="text" name="DriverId" value="@Model?.DriverId" class="form-control form-control-glass" />
            </div>

            <div class="col-md-2">
                <label class="form-label">Vehicle</label>
                <input type="number" name="VehicleId" value="@Model?.VehicleId" class="form-control form-control-glass" />
            </div>

            <div class="col-md-2">
                <label class="form-label">Client User</label>
                <input type="number" name="ClientUserId" value="@Model?.ClientUserId" class="form-control form-control-glass" />
            </div>

            <div class="col-md-2 d-flex gap-2">
                <button type="submit" class="btn-primary-glass w-100">
                    <i class="bi bi-funnel me-1"></i> Filter
                </button>
            </div>
        </div>
    </form>

    <!-- DOWNLOAD -->
    <form method="get" asp-action="DownloadInvoiceReport" class="mt-3">
        <input type="hidden" name="FromDate" value="@Model?.FromDate?.ToString("yyyy-MM-dd")" />
        <input type="hidden" name="ToDate" value="@Model?.ToDate?.ToString("yyyy-MM-dd")" />
        <input type="hidden" name="DriverId" value="@Model?.DriverId" />
        <input type="hidden" name="VehicleId" value="@Model?.VehicleId" />
        <input type="hidden" name="ClientUserId" value="@Model?.ClientUserId" />

        <button type="submit" class="btn-download">
            <i class="bi bi-download me-1"></i> Download PDF
        </button>
    </form>
</div>

<!-- TABLE -->
@if (Model?.Trips != null && Model.Trips.Any())
{
    <div class="table-responsive">
        <table class="table table-glass">
            <thead>
                <tr>
                    <th>Invoice</th>
                    <th>Date</th>
                    <th>Client</th>
                    <th>Driver</th>
                    <th>Vehicle</th>
                    <th class="text-end">Total</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var trip in Model.Trips)
                {
                    <tr>
                        <td class="fw-bold text-white">#@trip.Id</td>
                        <td>@trip.BookedDate.ToString("dd-MM-yyyy")</td>
                        <td>@trip.Client?.Name</td>
                        <td>@trip.Driver?.FullName</td>
                        <td>@trip.Vehicle?.VehicleNo</td>
                        <td class="text-end text-success fw-bold">₹@trip.TotalAmount</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else
{
    <div class="text-center mt-5 text-muted-light">
        <i class="bi bi-inbox fs-2 d-block mb-2"></i>
        No invoices found for selected filters.
    </div>
}
@model SharavaniTours.Models.Trip
@using SharavaniTours.Helpers
@using SharavaniTours.Models

@{
    Layout = null;

    var ds = Model.DutySlip;

    // =====================================================
    // 🚗 KM CALCULATION
    // =====================================================

    var totalKm = ds.EndKM - ds.StartKM;

    var baseKm = Model.RateCard.BaseKM ?? 0;

    var extraKmRate = Model.RateCard.ExtraKMRate ?? 0;

    var extraKm = Math.Max(0, totalKm - baseKm);

    // =====================================================
    // ⏱️ TIME CALCULATION
    // =====================================================

    var tripDuration = ds.EndTime - ds.StartTime;

    // 🔹 Total Hours
    var totalHours =
        (int)Math.Round(tripDuration.TotalHours);

    // 🔹 Total Days (Outstation)
    var totalDays =
        (decimal)Math.Floor(tripDuration.TotalDays);

    // 🔹 Base Hours
    var baseHours =
        Model.RateCard.BaseHours ?? 0;

    // 🔹 Extra Hours
    var extraHours = 0;

    // =====================================================
    // 🚕 LOCAL TRIP LOGIC
    // =====================================================

    if (Model.TripType ==
        SharavaniTours.Models.TripType.Local)
    {
        extraHours = Math.Max(
            0,
            totalHours - baseHours
        );
    }

    // =====================================================
    // 🌍 OUTSTATION LOGIC
    // =====================================================

    else
    {
        // Remaining hours after complete days
        extraHours = tripDuration.Hours;

        // Optional rounding
        if (tripDuration.Minutes >= 30)
        {
            extraHours++;
        }
    }

    // =====================================================
    // 💰 RATES
    // =====================================================

    var basePrice =
        Model.RateCard.BasePrice ?? 0;

    var extraHourRate =
        Model.RateCard.ExtraHourRate ?? 0;
}


<style>
    body {
        font-family: Arial, sans-serif;
        margin: 0;
    }

    .invoice-box {
        max-width: 210mm;
        margin: auto;
        padding: 10mm;
        border: 1px solid #000;
        box-sizing: border-box;
    }

    /* HEADER */
    .header {
        display: flex;
        border-bottom: 1px solid #000;
        padding: 5px;
    }

        .header img {
            height: 90px;
            width: auto;
        }

        .header div:first-child {
            width: 80px;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .header div:nth-child(2) {
            flex: 1;
            text-align: center;
            padding-top: 20px;
        }

        .header h2 {
            margin: 0;
            font-size: 18px;
        }

        .header p {
            margin: 2px 0;
            font-size: 12px;
        }

        .header div:nth-child(3) {
            width: 150px;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            text-align: right;
        }

    /* COMMON TABLE */
    table {
        width: 100%;
        border-collapse: collapse;
        font-size: 13px;
    }

    td, th {
        border: 1px solid #000;
        padding: 5px;
    }

    th {
        background: #f2f2f2;
    }

    /* DETAILS */
    .invoice-details {
        display: flex;
        border-bottom: 1px solid #000;
    }

        .invoice-details .left {
            width: 60%;
            padding: 8px;
            border-right: 1px solid #000;
        }

        .invoice-details .right {
            width: 40%;
            padding: 8px;
        }

    /* 3 COLUMN SECTION */
    .info-section {
        display: flex;
        border-bottom: 1px solid #000;
    }

        .info-section .col {
            width: 33.33%;
            padding: 8px;
            border-right: 1px solid #000;
        }

            .info-section .col:last-child {
                border-right: none;
            }

    .title {
        font-weight: bold;
        border-bottom: 1px solid #000;
        margin-bottom: 5px;
    }

    /* TRIP TABLE */
    .trip-details td:nth-child(odd) {
        background: #f2f2f2;
        font-weight: bold;
    }

    /* CHARGES */
    .charges-table td:nth-child(2),
    .charges-table td:nth-child(3),
    .charges-table td:nth-child(4) {
        text-align: center;
    }

    .text-right {
        text-align: right;
    }

    /* BOTTOM */
    .bottom-section {
        display: flex;
        border: 1px solid #000;
        border-top: none;
    }

    .bottom-left {
        width: 65%;
        padding: 10px;
        border-right: 1px solid #000;
    }

    .bottom-right {
        width: 35%;
        display: flex;
        flex-direction: column;
    }

    .sign-box {
        flex: 1;
        border-bottom: 1px solid #000;
        display: flex;
        align-items: flex-end;
        justify-content: center;
        padding-bottom: 10px;
    }

        .sign-box:last-child {
            border-bottom: none;
        }

    .note {
        font-size: 11px;
        margin-top: 10px;
    }

    .label_invoice {
        font-size:1.4rem;
    }

    .label_gst {
        font-size: 1.4rem;
    }

    /* PRINT */
    @@page {
        size: A4;
        margin: 8mm;
    }

    @@media print {
        .invoice-box {
            border: none;
        }
    }
</style>

<div class="invoice-box">
        <!-- HEADER -->
    <div class="header">
        <div>
            <img src="~/logo.png" />
        </div>

        <div>
            <h2>SHRAVANI TOURS & TRAVELS</h2>
            <p>
                Sr.No. 204/9, Siddhivinayak Colony, Road No. 4, Papde Wasti,<br />
                Fursungi 412308, Contact No. 07387473977
            </p>
        </div>

        <div>
            <p><strong class="label_invoice">Invoice</strong></p>
            <p class="label_gst">GSTIN: 27AJJPR6872R1ZZ</p>
        </div>
    </div>

    <!-- CLIENT -->
    <div class="invoice-details">
        <div class="left">
            <p><strong>To,</strong></p>
            <p><strong>Kansai Nerolac Paints Limited</strong></p>
            <p>
                28th Floor, A Wing, Marathon Futures,<br />
                NM Joshi Marg, Lower Parel, Mumbai - 400013
            </p>
            <p><strong>GST No:</strong> 27AAACK6137E1ZC</p>
        </div>

        <div class="right">
            <table>
                <tr>
                    <td>Date</td>
                    <td>@Model.BookedDate.ToString("dd/MM/yyyy")</td>
                </tr>
                <tr>
                    <td>Invoice No</td>
                    <td>@Model.Id</td>
                </tr>
                <tr>
                    <td>Itinerary Code</td>
                    <td>@Model.ItineraryCode</td>
                </tr>
                <tr>
                    <td>Duty Slip No</td>
                    <td>@Model.DutySlip?.DutySlipNo</td>
                </tr>
                <tr>
                    <td>Booked By</td>
                    <td>@Model.BookedBy</td>
                </tr>
            </table>

            <div class="mt-4 pt-3 text-right text-bold text-small" >
                <br />
                <span>@(Model.DropLocation)</span> :
                @(Model.TripType == SharavaniTours.Models.TripType.Local ? "LOCAL" : "OUTSTATION")
            </div>
        </div>
    </div>

    <!-- BILL / USER / CAB -->
    <div class="info-section">
        <div class="col">
            <div class="title">Bill To</div>
            <p><strong>Kansai Nerolac Paints Ltd</strong></p>
            <p>Bhukum, Pune 412115</p>
        </div>

        <div class="col">
            <div class="title">User Details</div>
            <p>Name: @Model.ClientUser?.FullName</p>
            <p>Mob: @Model.ClientUser?.MobileNo</p>
        </div>

        <div class="col">
            <div class="title">Cab Details</div>
            <p>Type: @Model.SentVehicle?.VehicleType.Name</p>
            <p>No: @Model.SentVehicle?.VehicleNo</p>
            <p>Driver: @Model.Driver?.FullName</p>
        </div>
    </div>

    <!-- TRIP -->
    <table class="trip-details">
        <tr>
            <td>Start Kms</td>
            <td>@ds.StartKM</td>
            <td>Start Date</td>
            <td>@ds.StartTime.ToString("dd/MM/yyyy")</td>
            <td>Start Time</td>
            <td>@ds.StartTime.ToString("hh:mm tt")</td>
        </tr>
        <tr>
            <td>Close Kms</td>
            <td>@ds.EndKM</td>
            <td>Close Date</td>
            <td>@ds.EndTime.ToString("dd/MM/yyyy")</td>
            <td>Close Time</td>
            <td>@ds.EndTime.ToString("hh:mm tt")</td>
        </tr>
        <tr>
            <td>Total</td>
            <td>@totalKm</td>
            <td>Days</td>
            <td>@((ds.EndTime - ds.StartTime).Days)</td>
            <td></td>
            <td></td>
        </tr>
    </table>

    <!-- CHARGES -->
    <table class="charges-table">

        <tr>
            <th>Particulars</th>
            <th>Qty</th>
            <th>Price</th>
            <th>Total</th>
        </tr>

        <!-- LOCAL / OUTSTATION -->
        @if (Model.TripType == SharavaniTours.Models.TripType.Local)
        {
            <tr>

                <td>
                    FIRST @Model.RateCard.BaseKM KM /
                    @Model.RateCard.BaseHours HRS
                </td>

                <td>1</td>

                <td>
                    @(Model.RateCard.BasePrice ?? 0)
                </td>

                <td>
                    @(Model.RateCard.BasePrice ?? 0)
                </td>

            </tr>
        }
        else
        {
            <tr>

                <td>
                    Outstation Charges
                    (@Model.RateCard.BaseKM KM Per Day)
                </td>

                <td>@totalDays</td>

                <td>
                    @(Model.RateCard.OutstationRatePerDay ?? 0)
                </td>

                <td>
                    @(
                        totalDays *
                        (Model.RateCard.OutstationRatePerDay ?? 0)
                    )
                </td>

            </tr>
        }

        <!-- EXTRA KM -->

        <tr>

            <td>Extra Kms</td>

            <td>@extraKm</td>

            <td>
                @(Model.RateCard.ExtraKMRate ?? 0)
            </td>

            <td>
                @(
                    extraKm *
                    (Model.RateCard.ExtraKMRate ?? 0)
                )
            </td>

        </tr>

        <!-- EXTRA HOURS -->

        <tr>

            <td>Extra Hrs</td>

            <td>@extraHours</td>

            <td>
                @(Model.RateCard.ExtraHourRate ?? 0)
            </td>

            <td>
                @(
                    extraHours *
                    (Model.RateCard.ExtraHourRate ?? 0)
                )
            </td>

        </tr>

        <!-- DRIVER -->

        <tr>

            <td>Driver Allowance</td>

            <!-- Qty -->
            <td>1</td>

            <!-- Price -->
            <td>
                @(Model.DriverAllowance > 0
                    ? Model.DriverAllowance
                    : 0)
            </td>

            <!-- Total -->
            <td>
                @(1 * (
                    Model.DriverAllowance > 0
                        ? Model.DriverAllowance
                        : 0
                ))
            </td>

        </tr>
            <td>Toll + Parking</td>

            <td></td>

            <td></td>

            <td>
                @(ds.TollCharges + ds.ParkingCharges)
            </td>

        </tr>

        <!-- TOTAL -->

        <tr>

            <td colspan="3"
                class="text-right">

                <strong>Total Amount</strong>

            </td>

            <td>
                <strong>
                    @(Model.TotalAmount)
                </strong>
            </td>

        </tr>

    </table>

    <!-- BOTTOM -->
    <div class="bottom-section">
        <div class="bottom-left">
            <p><strong>RUPEES IN WORD</strong></p>
            <p style="margin-bottom:100px;">@NumberHelper.NumberToWords((int)(Model.TotalAmount)) Rupees Only</p>

            <p class="note">
                Kms & Hrs will be calculated from office to office.<br />
                (Vehicle are insurred against accident of damage crashed.)<br />
                insurance of passanger is not insured in thie quited rates.<br />

                Cancellation charges will be ₹1000/- compulsory.<br />
                Toll and parking paid by party.
            </p>
        </div>

        <div class="bottom-right">
            <div class="sign-box">Customers Sign</div>
            <div class="sign-box">For Shravani Tours & Travels</div>
        </div>
    </div>


</div>

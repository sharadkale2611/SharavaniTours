@page
@model LoginModel

@{
    ViewData["Title"] = "Log in";
    Layout = "~/Views/Shared/_PublicLayout.cshtml";

}

<style>
    /* Specific overrides for Identity pages to match public theme */
    .login-header {
        text-align: center;
        margin-bottom: 2rem;
    }

        .login-header h1 {
            font-weight: 800;
            background: linear-gradient(135deg, #f8fafc, #94a3b8);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin-bottom: 0.5rem;
        }

        .login-header p {
            color: #94a3b8;
            font-size: 1.1rem;
        }

    /* Input Styling */
    .form-floating > .form-control {
        background: rgba(15, 23, 42, 0.6);
        border: 1px solid rgba(255, 255, 255, 0.1);
        color: white;
        border-radius: 12px;
    }

        .form-floating > .form-control:focus {
            background: rgba(15, 23, 42, 0.8);
            border-color: #3b82f6;
            box-shadow: 0 0 0 0.25rem rgba(59, 130, 246, 0.25);
            color: white;
        }

    .form-floating > label {
        color: #94a3b8;
    }

    .form-floating > .form-control:focus ~ label,
    .form-floating > .form-control:not(:placeholder-shown) ~ label {
        color: #3b82f6;
    }

    /* Checkbox styling */
    .form-check-input {
        background-color: rgba(15, 23, 42, 0.6);
        border: 1px solid rgba(255, 255, 255, 0.2);
    }

        .form-check-input:checked {
            background-color: #3b82f6;
            border-color: #3b82f6;
        }

    /* Link styling */
    .identity-links a {
        color: #94a3b8;
        text-decoration: none;
        font-size: 0.9rem;
        transition: color 0.2s;
    }

        .identity-links a:hover {
            color: #3b82f6;
        }

    .divider {
        height: 1px;
        background: rgba(255, 255, 255, 0.1);
        margin: 1.5rem 0;
    }
</style>

<div class="row justify-content-center">
    <div class="col-12 col-md-6 col-lg-5">
        <div class="login-header">
            <h1>Welcome Back</h1>
            <p>Enter your credentials to access your account</p>
        </div>

        <section>
            <form id="account" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>

                <div class="form-floating mb-3">
                    <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                    <label asp-for="Input.Email">Email Address</label>
                    <span asp-validation-for="Input.Email" class="text-danger small"></span>
                </div>

                <div class="form-floating mb-3">
                    <input asp-for="Input.Password" class="form-control" autocomplete="current-password" aria-required="true" placeholder="password" />
                    <label asp-for="Input.Password">Password</label>
                    <span asp-validation-for="Input.Password" class="text-danger small"></span>
                </div>

                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div class="form-check">
                        <input class="form-check-input" asp-for="Input.RememberMe" />
                        <label asp-for="Input.RememberMe" class="form-check-label text-light">
                            @Html.DisplayNameFor(m => m.Input.RememberMe)
                        </label>
                    </div>
                    <div class="identity-links">
                        <a id="forgot-password" asp-page="./ForgotPassword">Forgot password?</a>
                    </div>
                </div>

                <button id="login-submit" type="submit" class="w-100 btn btn-lg btn-primary py-3 fw-bold shadow-lg"
                        style="background: #3b82f6; border: none; border-radius: 12px;">
                    Sign In
                </button>

                <div class="divider"></div>

                @* <div class="identity-links text-center"> *@
                @*     <p class="mb-2 text-white-50">Don't have an account?</p> *@
                @*     <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="fw-bold" style="color: #3b82f6;">Register as a new user</a> *@
                @*     <div class="mt-3"> *@
                @*         <a id="resend-confirmation" asp-page="./ResendEmailConfirmation">Resend email confirmation</a> *@
                @*     </div> *@
                @* </div> *@
            </form>
        </section>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        // Subtle GSAP entrance for the form elements
        gsap.from("#account > div, #account > button", {
            opacity: 0,
            y: 20,
            stagger: 0.1,
            duration: 0.8,
            ease: "power3.out"
        });
    </script>
}
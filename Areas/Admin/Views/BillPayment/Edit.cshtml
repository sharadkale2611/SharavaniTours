@model SharavaniTours.Models.BillPayment

@using SharavaniTours.Models

@{
    ViewData["Title"] = "Edit Bill Payment";
}

<style>

    .form-glass-container {
        max-width: 1100px;
        margin: 0 auto;
    }

    .glass-card {
        background: rgba(15, 23, 42, 0.55);
        border: 1px solid rgba(255,255,255,0.06);
        border-radius: 18px;
        padding: 28px;
        backdrop-filter: blur(14px);
    }

    .section-title {
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 1px;
        text-transform: uppercase;
        color: #3b82f6;
        margin-bottom: 18px;
        border-left: 3px solid #3b82f6;
        padding-left: 10px;
    }

    label {
        color: #94a3b8;
        font-size: 0.78rem;
        font-weight: 600;
        margin-bottom: 5px;
    }

    .form-control-glass {
        background: rgba(15, 23, 42, 0.4) !important;
        border: 1px solid rgba(255,255,255,0.1) !important;
        color: #fff !important;
        border-radius: 10px;
        min-height: 42px;
        padding: 10px 14px;
    }

        .form-control-glass:focus {
            border-color: #3b82f6 !important;
            box-shadow: 0 0 0 3px rgba(59,130,246,0.15);
        }

    select.form-control-glass option {
        background: #0f172a;
        color: #fff;
    }

    .btn-save {
        background: #3b82f6;
        border: none;
        color: #fff;
        padding: 10px 28px;
        border-radius: 10px;
        font-weight: 700;
    }

</style>

<div class="form-glass-container">

    <div class="d-flex justify-content-between
        align-items-center mb-4">

        <div>

            <h2 class="fw-bold text-white mb-1">
                ✏️ Edit Bill Payment
            </h2>

            <p style="color:#94a3b8;">
                Update bill and payment details
            </p>

        </div>

        <a asp-action="Index"
               class="btn btn-outline-light">

            ← Back

        </a>

    </div>

    <div class="glass-card">

        <form asp-action="Edit"
              method="post">

            @Html.AntiForgeryToken()

            <input type="hidden"
                   asp-for="Id" />

            <!-- VALIDATION -->
            @if (!ViewData.ModelState.IsValid)
            {
                <div asp-validation-summary="All"
                     class="alert alert-danger mb-4">
                </div>
            }

            <!-- BILL INFO -->

            <div class="section-title">
                Bill Information
            </div>

            <div class="row">

                <div class="col-md-3 mb-3">

                    <label>Bill Date</label>

                    <input asp-for="BillDate"
                           type="date"
                           class="form-control-glass w-100" />

                </div>

                <div class="col-md-3 mb-3">

                    <label>Bill No</label>

                    <input asp-for="BillNo"
                           class="form-control-glass w-100" />

                </div>

                <div class="col-md-3 mb-3">

                    <label>Duty Slip No</label>

                    <input asp-for="DutySlipNo"
                           class="form-control-glass w-100" />

                </div>

                <div class="col-md-3 mb-3">

                    <label>Location</label>

                    <input asp-for="Location"
                           class="form-control-glass w-100" />

                </div>

            </div>

            <!-- VEHICLE -->

            <div class="section-title mt-4">
                Vehicle Details
            </div>

            <div class="row">

                <div class="col-md-6 mb-3">

                    <label>Vehicle No</label>

                    <input asp-for="VehicleNo"
                           class="form-control-glass w-100" />

                </div>

                <div class="col-md-6 mb-3">

                    <label>Vehicle Type</label>

                    <input asp-for="VehicleType"
                           class="form-control-glass w-100" />

                </div>

            </div>

            <!-- AMOUNTS -->

            <div class="section-title mt-4">
                Amount Details
            </div>

            <div class="row">

                <div class="col-md-3 mb-3">

                    <label>Amount</label>

                    <input asp-for="Amount"
                           type="number"
                           step="0.01"
                           class="form-control-glass w-100" />

                </div>

                <div class="col-md-3 mb-3">

                    <label>Toll/Parking</label>

                    <input asp-for="TollParkingAmount"
                           type="number"
                           step="0.01"
                           class="form-control-glass w-100" />

                </div>

                <div class="col-md-3 mb-3">

                    <label>TDS</label>

                    <input asp-for="TDS"
                           type="number"
                           step="0.01"
                           class="form-control-glass w-100" />

                </div>

                <div class="col-md-3 mb-3">

                    <label>Final Amount</label>

                    <input asp-for="FinalAmount"
                           type="number"
                           step="0.01"
                           class="form-control-glass w-100" />

                </div>

            </div>

            <!-- PAYMENT -->

            <div class="section-title mt-4">
                Payment Information
            </div>

            <div class="row">

                <div class="col-md-4 mb-3">

                    <label>Payment Status</label>

                    <select asp-for="PaymentStatus"
                            class="form-control-glass
                        form-select">

                        <option value="Pending">
                            Pending
                        </option>

                        <option value="Partial">
                            Partial
                        </option>

                        <option value="Paid">
                            Paid
                        </option>

                        <option value="Cancelled">
                            Cancelled
                        </option>

                    </select>

                </div>

                <div class="col-md-4 mb-3">

                    <label>Payment Date</label>

                    <input asp-for="PaymentDate"
                           type="date"
                           class="form-control-glass w-100" />

                </div>

                <div class="col-md-4 mb-3">

                    <label>Remarks</label>

                    <input asp-for="Remarks"
                           class="form-control-glass w-100" />

                </div>

            </div>

            <!-- ACTIONS -->

            <div class="d-flex justify-content-end
                mt-4">

                <button type="submit"
                        class="btn-save">

                    💾 Save Changes

                </button>

            </div>

        </form>

    </div>

</div>

@section Scripts {

    @{
        await Html.RenderPartialAsync(
            "_ValidationScriptsPartial"
        );
    }

}
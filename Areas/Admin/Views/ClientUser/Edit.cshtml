@model SharavaniTours.Models.ClientUser

@{
    ViewData["Title"] = "Update Client Staff";
}

<style>
    /* Styles are consistent with the Create page */
    .form-glass-container {
        max-width: 600px;
        margin: 0 auto;
    }

    .form-label {
        color: #94a3b8;
        font-weight: 600;
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 8px;
    }

    .form-control-glass {
        background: rgba(15, 23, 42, 0.4) !important;
        border: 1px solid rgba(255, 255, 255, 0.1) !important;
        color: #fff !important;
        padding: 12px 16px;
        border-radius: 12px;
    }

    select.form-control-glass option {
        background: #1e293b;
        color: #fff;
    }

    .btn-update {
        background: #f59e0b;
        color: white;
        border: none;
        padding: 12px 30px;
        border-radius: 10px;
        font-weight: 700;
        transition: all 0.3s;
        box-shadow: 0 4px 15px rgba(245, 158, 11, 0.3);
    }

        .btn-update:hover {
            background: #d97706;
            transform: translateY(-2px);
        }
</style>

<div class="form-glass-container">
    <div class="d-flex align-items-center gap-3 mb-4">
        <div class="icon-box" style="width: 45px; height: 45px; background: rgba(245, 158, 11, 0.1); border-radius: 12px; display: flex; align-items: center; justify-content: center;">
            <i class="bi bi-person-gear text-warning fs-4"></i>
        </div>
        <div>
            <h2 class="fw-800 mb-0" style="color: #fff;">Edit Client User</h2>
            <p class="text-slate-light mb-0" style="color: #94a3b8 !important;">Modifying details for <span class="text-white">@Model.FullName</span></p>
        </div>
    </div>

    <form asp-action="Edit" method="post" class="mt-4">
        <input type="hidden" asp-for="Id" />

        <div class="row g-4">
            <div class="col-12">
                <label class="form-label">Client / Company</label>
                <select asp-for="ClientId" asp-items="ViewBag.Clients" class="form-control form-control-glass">
                </select>
            </div>

            <div class="col-12">
                <label asp-for="FullName" class="form-label">Full Name</label>
                <input asp-for="FullName" class="form-control form-control-glass" />
            </div>

            <div class="col-12">
                <label asp-for="MobileNo" class="form-label">Mobile Number</label>
                <input asp-for="MobileNo" class="form-control form-control-glass" />
            </div>

            <div class="col-12 d-flex align-items-center justify-content-between mt-5">
                <a asp-action="Index" class="text-decoration-none fw-600" style="color: #94a3b8;">Back to List</a>
                <button type="submit" class="btn-update">
                    <i class="bi bi-arrow-repeat me-2"></i> Update User
                </button>
            </div>
        </div>
    </form>
</div>
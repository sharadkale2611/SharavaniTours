@model SharavaniTours.Models.ClientUser

@{
    ViewData["Title"] = "Add Client Staff";
}

<style>
    .form-glass-container {
        max-width: 600px;
        margin: 0 auto;
    }

    .form-label {
        color: #94a3b8;
        font-weight: 600;
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 8px;
    }

    .form-control-glass {
        background: rgba(15, 23, 42, 0.4) !important;
        border: 1px solid rgba(255, 255, 255, 0.1) !important;
        color: #fff !important;
        padding: 12px 16px;
        border-radius: 12px;
        transition: all 0.3s ease;
    }

    /* Styling the dropdown options for dark theme */
    select.form-control-glass option {
        background: #1e293b;
        color: #fff;
    }

    .form-control-glass:focus {
        border-color: #3b82f6 !important;
        box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.15);
        outline: none;
    }

    .btn-save {
        background: #3b82f6;
        color: white;
        border: none;
        padding: 12px 30px;
        border-radius: 10px;
        font-weight: 700;
        transition: all 0.3s;
        box-shadow: 0 4px 15px rgba(59, 130, 246, 0.3);
    }

        .btn-save:hover {
            background: #2563eb;
            transform: translateY(-2px);
        }
</style>

<div class="form-glass-container">
    <div class="d-flex align-items-center gap-3 mb-4">
        <div class="icon-box" style="width: 45px; height: 45px; background: rgba(59, 130, 246, 0.1); border-radius: 12px; display: flex; align-items: center; justify-content: center;">
            <i class="bi bi-person-plus-fill text-primary fs-4"></i>
        </div>
        <div>
            <h2 class="fw-800 mb-0" style="color: #fff;">Add Client User</h2>
            <p class="text-slate-light mb-0" style="color: #94a3b8 !important;">Assign a representative to a corporate client.</p>
        </div>
    </div>

    <form asp-action="Create" method="post" class="mt-4">
        <div class="row g-4">
            <div class="col-12">
                <label class="form-label">Associated Client</label>
                <select asp-for="ClientId" class="form-control form-control-glass">
                    <option value="">-- Select Company --</option>
                    @foreach (var c in ViewBag.Clients)
                    {
                        <option value="@c.Id">@c.Name</option>
                    }
                </select>
            </div>

            <div class="col-12">
                <label asp-for="FullName" class="form-label">Full Name</label>
                <input asp-for="FullName" class="form-control form-control-glass" placeholder="e.g. John Doe" />
            </div>

            <div class="col-12">
                <label asp-for="MobileNo" class="form-label">Mobile Number</label>
                <input asp-for="MobileNo" class="form-control form-control-glass" placeholder="e.g. +91 98765 43210" />
            </div>

            <div class="col-12 d-flex align-items-center justify-content-between mt-5">
                <a asp-action="Index" class="text-decoration-none fw-600" style="color: #94a3b8;">Cancel</a>
                <button type="submit" class="btn-save">
                    <i class="bi bi-check-lg me-2"></i> Save User
                </button>
            </div>
        </div>
    </form>
</div>
@model IEnumerable<SharavaniTours.Models.ClientUser>

@{
    ViewData["Title"] = "Client User Directory";
}

<style>
    /* Table enhancements matching Client Directory */
    .table-glass {
        color: #e2e8f0;
        vertical-align: middle;
        background: rgba(238, 238, 238, 0.07); /* Matches your #eeeeee13 */
    }

        .table-glass thead th {
            background: linear-gradient(180deg, rgba(30, 41, 59, 0.8) 0%, rgba(15, 23, 42, 0.9) 100%);
            color: #3b82f6;
            font-weight: 700;
            text-transform: uppercase;
            font-size: 0.75rem;
            letter-spacing: 1px;
            border-bottom: 2px solid rgba(255, 255, 255, 0.05);
            padding: 15px;
        }

        .table-glass td {
            padding: 16px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
            background: transparent;
        }

        .table-glass tr:hover td {
            background: rgba(255, 255, 255, 0.02);
            color: #fff;
        }

    /* Action Icon Buttons */
    .action-btn {
        width: 32px;
        height: 32px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 8px;
        transition: all 0.2s;
        text-decoration: none !important;
        border: none;
    }

    .btn-edit {
        color: #3b82f6;
        background: rgba(59, 130, 246, 0.1);
    }

        .btn-edit:hover {
            background: #3b82f6;
            color: white;
        }

    .btn-delete {
        color: #ef4444;
        background: rgba(239, 68, 68, 0.1);
    }

        .btn-delete:hover {
            background: #ef4444;
            color: white;
        }

    .user-name-cell {
        font-weight: 600;
        color: #fff !important;
    }

    .text-slate-light {
        color: #94a3b8 !important;
        font-size: 0.85rem;
    }

    .client-badge {
        background: rgba(59, 130, 246, 0.1);
        color: #3b82f6;
        border: 1px solid rgba(59, 130, 246, 0.2);
        padding: 5px 10px;
        border-radius: 6px;
        font-size: 0.8rem;
    }
</style>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-800 mb-1" style="color: #fff;">Client Users</h2>
        <p class="text-slate-light mb-0">Manage individual contact persons for your corporate clients.</p>
    </div>
    <a asp-area="Admin" asp-controller="ClientUser" asp-action="Create" class="btn btn-primary px-4 py-2"
       style="background: #3b82f6; border: none; border-radius: 10px; font-weight: 600;">
        <i class="bi bi-person-plus me-2"></i> Add Client User
    </a>
</div>

<div class="table-responsive">
    <table class="table table-glass">
        <thead>
            <tr>
                <th>Company / Client</th>
                <th>Full Name</th>
                <th>Mobile Number</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var u in Model)
            {
                <tr>
                    <td>
                        <span class="client-badge">
                            <i class="bi bi-building me-1"></i> @u.Client?.Name
                        </span>
                    </td>
                    <td class="user-name-cell">
                        @u.FullName
                    </td>
                    <td>
                        <a href="tel:@u.MobileNo" class="text-decoration-none text-slate-light">
                            <i class="bi bi-phone me-1 text-primary"></i> @u.MobileNo
                        </a>
                    </td>
                    <td class="text-end">
                        <div class="d-flex justify-content-end gap-2">
                            <a asp-action="Edit" asp-route-id="@u.Id" class="action-btn btn-edit" title="Edit User">
                                <i class="bi bi-pencil-square"></i>
                            </a>

                            <form asp-action="Delete" asp-route-id="@u.Id" method="post" style="display:inline;">
                                <button type="submit" class="action-btn btn-delete"
                                        title="Delete User"
                                        onclick="return confirm('Are you sure you want to delete @u.FullName?')">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="4" class="text-center py-5 text-slate-light">
                        <i class="bi bi-people fs-2 d-block mb-2"></i>
                        No client users found.
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
    <script>
        // Smooth entrance animation
        gsap.from("tbody tr", {
            opacity: 0,
            x: -10,
            stagger: 0.05,
            duration: 0.4,
            ease: "power2.out"
        });
    </script>
}
@model SharavaniTours.Models.Trip

@{
    ViewData["Title"] = "Dispatch New Trip";
}

<style>
    .form-glass-container {
        max-width: 850px;
        margin: 0 auto;
    }

    .section-label {
        font-size: 0.7rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        color: #3b82f6;
        margin-bottom: 20px;
        display: block;
        border-left: 3px solid #3b82f6;
        padding-left: 10px;
    }

    .form-label {
        color: #94a3b8;
        font-weight: 600;
        font-size: 0.85rem;
        margin-bottom: 8px;
    }

    .form-control-glass {
        background: rgba(15, 23, 42, 0.4) !important;
        border: 1px solid rgba(255, 255, 255, 0.1) !important;
        color: #fff !important;
        border-radius: 10px;
        padding: 10px 15px;
    }

        .form-control-glass:focus {
            border-color: #3b82f6 !important;
            box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.15);
        }

    select.form-control-glass option {
        background: #1e293b;
        color: #fff;
    }

    .btn-dispatch {
        background: linear-gradient(135deg, #3b82f6, #2563eb);
        color: white;
        border: none;
        padding: 12px 40px;
        border-radius: 10px;
        font-weight: 700;
        box-shadow: 0 4px 15px rgba(59, 130, 246, 0.3);
    }
</style>

<div class="form-glass-container">
    <div class="d-flex align-items-center gap-3 mb-5">
        <div class="icon-box" style="width: 45px; height: 45px; background: rgba(59, 130, 246, 0.1); border-radius: 12px; display: flex; align-items: center; justify-content: center;">
            <i class="bi bi-map-fill text-primary fs-4"></i>
        </div>
        <div>
            <h2 class="fw-800 mb-0" style="color: #fff;">Create New Trip</h2>
            <p class="text-slate-light mb-0">Assign resources and define trip parameters.</p>
        </div>
    </div>

    @if (!ViewData.ModelState.IsValid)
    {
        <div asp-validation-summary="All" class="alert alert-danger border-0 bg-danger bg-opacity-10 text-danger mb-4 rounded-3 small"></div>
    }

    <form asp-area="Admin" asp-controller="Trip" asp-action="Create" method="post">
        @Html.AntiForgeryToken()

        <div class="row g-4">
            <div class="col-12"><span class="section-label">Resource Assignment</span></div>

            <div class="col-md-6">
                <label class="form-label">Client</label>
                <select asp-for="ClientId" id="clientDropdown" class="form-control-glass form-select">
                    <option value="">-- Select Client --</option>
                    @foreach (var c in ViewBag.Clients)
                    {
                        <option value="@c.Id">@c.Name</option>
                    }
                </select>
                <span asp-validation-for="ClientId" class="text-danger small"></span>
            </div>

            <div class="col-md-6">
                <label class="form-label">Client Contact Person</label>
                <select asp-for="ClientUserId" id="clientUserDropdown" class="form-control-glass form-select">
                    <option value="">-- Select User --</option>
                    @foreach (var u in (ViewBag.ClientUsers ?? new List<SharavaniTours.Models.ClientUser>()))
                    {
                        <option value="@u.Id">@u.FullName (@u.MobileNo)</option>
                    }
                </select>
            </div>

            <div class="col-md-6">
                <label class="form-label">Driver</label>
                <select asp-for="DriverId" class="form-control-glass form-select">
                    <option value="">-- Select Driver --</option>
                    @foreach (var d in ViewBag.Drivers)
                    {
                        <option value="@d.Id">@(d.FullName ?? d.Email)</option>
                    }
                </select>
            </div>

            <div class="col-md-6">
                <label class="form-label">Vehicle</label>
                <select asp-for="VehicleId" class="form-control-glass form-select">
                    <option value="">-- Select Vehicle --</option>
                    @foreach (var v in ViewBag.Vehicles)
                    {
                        <option value="@v.Id">@v.VehicleNo (@v.Type)</option>
                    }
                </select>
            </div>

            <div class="col-12 mt-5"><span class="section-label">Billing & Logistics</span></div>

            <div class="col-md-4">
                <label class="form-label">Rate Card</label>
                <select asp-for="RateCardId" class="form-control-glass form-select">
                    <option value="">-- Select Rate --</option>
                    @foreach (var r in ViewBag.RateCards)
                    {
                        <option value="@r.Id">@r.Name (₹@r.BasePrice)</option>
                    }
                </select>
            </div>

            <div class="col-md-4">
                <label class="form-label">Booked By</label>
                <input asp-for="BookedBy" class="form-control-glass w-100" placeholder="Person Name" />
            </div>

            <div class="col-md-4">
                <label class="form-label">Driver Allowance (₹)</label>
                <input asp-for="DriverAllowance" class="form-control-glass w-100" type="number" step="0.01" />
            </div>

            <div class="col-12 d-flex align-items-center justify-content-between mt-5 pt-4">
                <a asp-action="Index" class="text-decoration-none fw-600 text-slate-light" style="color:#94a3b8">Cancel</a>
                <button type="submit" class="btn-dispatch">
                    <i class="bi bi-send-check me-2"></i> Create & Dispatch
                </button>
            </div>
        </div>
    </form>
</div>
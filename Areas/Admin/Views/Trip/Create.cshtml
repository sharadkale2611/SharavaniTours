
@model SharavaniTours.Models.Trip

<style>
    .form-glass-container {
        max-width: 850px;
        margin: 0 auto;
    }

    .section-label {
        font-size: 0.7rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        color: #3b82f6;
        margin-bottom: 20px;
        display: block;
        border-left: 3px solid #3b82f6;
        padding-left: 10px;
    }

    .form-label {
        color: #94a3b8;
        font-weight: 600;
        font-size: 0.85rem;
        margin-bottom: 8px;
    }

    .form-control-glass {
        background: rgba(15, 23, 42, 0.4) !important;
        border: 1px solid rgba(255, 255, 255, 0.1) !important;
        color: #fff !important;
        border-radius: 10px;
        padding: 10px 15px;
    }

        .form-control-glass:focus {
            border-color: #3b82f6 !important;
            box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.15);
        }

    select.form-control-glass option {
        background: #1e293b;
        color: #fff;
    }

    .btn-dispatch {
        background: linear-gradient(135deg, #3b82f6, #2563eb);
        color: white;
        border: none;
        padding: 12px 40px;
        border-radius: 10px;
        font-weight: 700;
        box-shadow: 0 4px 15px rgba(59, 130, 246, 0.3);
    }
</style>


<div class="form-glass-container">

    <h2 class="text-white mb-4">🚗 Create New Trip</h2>

    <form asp-area="Admin" asp-controller="Trip" asp-action="Create" method="post">

        <div class="row g-4">

            <!-- 🔹 CLIENT -->
            <div class="col-12"><span class="section-label">Client Details</span></div>

            <div class="col-md-6">
                <label>Client</label>
                <select asp-for="ClientId" class="form-control-glass form-select">
                    <option value="">Select Client</option>
                    @foreach (var c in ViewBag.Clients)
                    {
                        <option value="@c.Id">@c.Name</option>
                    }
                </select>
            </div>

            <div class="col-md-6">
                <label>Contact Person</label>
                <select asp-for="ClientUserId" class="form-control-glass form-select">
                    <option value="">Select User</option>
                    @foreach (var u in ViewBag.ClientUsers)
                    {
                        <option value="@u.Id">@u.FullName (@u.MobileNo)</option>
                    }
                </select>
            </div>

            <!-- 🔹 VEHICLE -->
            <div class="col-12 mt-4"><span class="section-label">Vehicle Assignment</span></div>

            <div class="col-md-6">
                <label>Vehicle</label>
                <select asp-for="RequestedVehicleId" id="vehicleDropdown" class="form-control-glass form-select">
                    <option value="">Select Vehicle</option>
                    @foreach (var v in ViewBag.Vehicles)
                    {
                        <option value="@v.Id">@v.VehicleNo (@v.VehicleType.Name)</option>
                    }
                </select>
            </div>

            <div class="col-md-6">
                <label>Driver</label>
                <select asp-for="DriverId" class="form-control-glass form-select">
                    <option value="">Select Driver</option>
                    @foreach (var d in ViewBag.Drivers)
                    {
                        <option value="@d.Id">@d.FullName</option>
                    }
                </select>
            </div>

            <!-- 🔹 PRICING -->
            <div class="col-12 mt-4"><span class="section-label">Pricing</span></div>

            <div class="col-md-6">
                <label>Rate Card</label>
                <select asp-for="RateCardId" id="rateCardDropdown"
                        class="form-control-glass form-select" disabled>
                    <option value="">Select Rate</option>
                </select>
            </div>

            <div class="col-md-6">
                <label>Driver Allowance (₹)</label>
                <input asp-for="DriverAllowance" id="driverAllowance"
                       class="form-control-glass w-100" type="number" />
            </div>

            <!-- 🔹 TRIP DETAILS -->
            <div class="col-12 mt-4"><span class="section-label">Trip Info</span></div>

            <div class="col-md-6">
                <label>Pickup Location</label>
                <input asp-for="PickupLocation" class="form-control-glass w-100" />
            </div>

            <div class="col-md-6">
                <label>Drop Location</label>
                <input asp-for="DropLocation" class="form-control-glass w-100" />
            </div>

            <div class="col-md-6">
                <label>Booked By</label>
                <input asp-for="BookedBy" class="form-control-glass w-100" />
            </div>

            <!-- 🔹 SUBMIT -->
            <div class="col-12 mt-5">
                <button class="btn-dispatch w-100">
                    🚀 Create Trip
                </button>
            </div>

        </div>
    </form>
</div>

<script>
    let rateCardData = [];

    // 🔹 Vehicle change
    document.getElementById("vehicleDropdown").addEventListener("change", function () {

        const vehicleId = this.value;
        const rateDropdown = document.getElementById("rateCardDropdown");

        rateDropdown.innerHTML = '<option value="">Select Rate</option>';

        if (!vehicleId) {
            rateDropdown.disabled = true;
            return;
        }

        rateDropdown.disabled = false;

        fetch('/Admin/Trip/GetRateCardsByVehicle?vehicleId=' + vehicleId)
            .then(res => res.json())
            .then(data => {

                rateCardData = data;

                data.forEach(r => {

                    const price = r.price ?? 0;

                    rateDropdown.insertAdjacentHTML('beforeend',
                        `<option value="${r.id}">
                            ${r.name} (₹${price})
                        </option>`);
                });
            });
    });


    // 🔹 RateCard change → set DriverAllowance
    document.getElementById("rateCardDropdown").addEventListener("change", function () {

        const selectedId = this.value;

        const selected = rateCardData.find(x => x.id == selectedId);

        if (!selected) return;

        document.getElementById("driverAllowance").value =
            selected.driverAllowance ?? 0;
    });
</script>
@model IEnumerable<SharavaniTours.Models.RateCard>
@using SharavaniTours.Models

@{
    ViewData["Title"] = "Pricing Strategy";
}

<style>
    /* Consistent Table Styling */
    .table-glass {
        color: #e2e8f0;
        vertical-align: middle;
        background: rgba(238, 238, 238, 0.07);
    }

        .table-glass thead th {
            background: linear-gradient(180deg, rgba(30, 41, 59, 0.8) 0%, rgba(15, 23, 42, 0.9) 100%);
            color: #3b82f6;
            font-weight: 700;
            text-transform: uppercase;
            font-size: 0.65rem;
            letter-spacing: 0.5px;
            border-bottom: 2px solid rgba(255, 255, 255, 0.05);
            padding: 12px 8px;
            white-space: nowrap;
        }

        .table-glass td {
            padding: 12px 8px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
            background: transparent;
            font-size: 0.85rem;
            color: #eee !important;
        }

        .table-glass tr:hover td {
            background: rgba(255, 255, 255, 0.02);
        }

    .col-base {
        color: #f8fafc;
        font-weight: 600;
    }

    .col-extra {
        color: #94a3b8;
    }

    .col-outstation {
        color: #60a5fa;
    }

    .currency-symbol {
        color: #3b82f6;
        font-size: 0.75rem;
        margin-right: 2px;
    }

    /* Type Badge */
    .badge-type {
        font-size: 0.65rem;
        padding: 3px 8px;
        border-radius: 20px;
        font-weight: 700;
    }

    .badge-local {
        background: rgba(16, 185, 129, 0.15);
        color: #10b981;
    }

    .badge-outstation {
        background: rgba(59, 130, 246, 0.15);
        color: #3b82f6;
    }

    .muted-value {
        color: #64748b;
        font-style: italic;
    }

    /* Action Buttons */
    .action-btn {
        width: 30px;
        height: 30px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 6px;
        transition: all 0.2s;
        text-decoration: none !important;
        border: none;
    }

    .btn-edit {
        color: #3b82f6;
        background: rgba(59, 130, 246, 0.1);
    }

        .btn-edit:hover {
            background: #3b82f6;
            color: white;
        }

    .btn-delete {
        color: #ef4444;
        background: rgba(239, 68, 68, 0.1);
    }

        .btn-delete:hover {
            background: #ef4444;
            color: white;
        }

    .text-slate-light {
        color: #94a3b8 !important;
        font-size: 0.85rem;
    }
</style>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-800 mb-1" style="color: #fff;">Rate Cards</h2>
        <p class="text-slate-light mb-0">Define local and outstation pricing structures for billing.</p>
    </div>
    <a asp-action="Create" class="btn btn-primary px-4 py-2"
       style="background: #3b82f6; border: none; border-radius: 10px; font-weight: 600;">
        <i class="bi bi-plus-lg me-2"></i> Add New Rate
    </a>
</div>

<div class="table-responsive">
    <table class="table table-glass">
        <thead>
            <tr>
                <th>Plan Name</th>
                <th>Vehicle</th>
                <th>Type</th>
                <th>Base Package</th>
                <th>Extra Charges</th>
                <th>Outstation</th>
                <th>Additional</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var r in Model)
            {
                <tr>
                    <!-- PLAN -->
                    <td class="col-base">
                        <i class="bi bi-tag-fill me-2 text-primary" style="font-size: 0.8rem;"></i>
                        @r.Name
                    </td>

                    <!-- VEHICLE -->
                    <td>
                        <span class="text-white">@r.VehicleType?.Name</span>
                    </td>

                    <!-- TYPE -->
                    <td>
                        @if (r.TripType == TripType.Local)
                        {
                            <span class="badge-type badge-local">Local</span>
                        }
                        else
                        {
                            <span class="badge-type badge-outstation">Outstation</span>
                        }
                    </td>

                    <!-- BASE -->
                    <td>
                        @if (r.TripType == TripType.Local)
                        {
                            <div>
                                <span class="text-white">@r.BaseKM</span>
                                <small class="text-slate-light">KM</small>
                                <span class="mx-1 text-slate-light">/</span>
                                <span class="text-white">@r.BaseHours</span>
                                <small class="text-slate-light">Hrs</small>
                            </div>
                            <div class="col-base">
                                <span class="currency-symbol">₹</span>@r.BasePrice
                            </div>
                        }
                        else
                        {
                            <span class="muted-value">--</span>
                        }
                    </td>

                    <!-- EXTRA -->
                    <td>
                        @if (r.TripType == TripType.Local)
                        {
                            <div class="col-extra">
                                <span class="currency-symbol">₹</span>@r.ExtraKMRate /km
                            </div>
                            <div class="col-extra">
                                <span class="currency-symbol">₹</span>@r.ExtraHourRate /hr
                            </div>
                        }
                        else
                        {
                            <div class="col-extra">
                                <span class="currency-symbol">₹</span>@r.ExtraKMRate /km
                            </div>
                        }
                    </td>

                    <!-- OUTSTATION -->
                    <td>
                        @if (r.TripType == TripType.Outstation)
                        {
                            <div class="col-outstation">
                                @r.OutstationPerDayKM <small>KM/day</small>
                            </div>
                            <div class="fw-bold col-outstation">
                                <span class="currency-symbol">₹</span>@r.OutstationRatePerDay
                            </div>
                        }
                        else
                        {
                            <span class="muted-value">--</span>
                        }
                    </td>

                    <!-- ADDITIONAL -->
                    <td>
                        <div>Night: ₹@(r.NightCharges ?? 0)</div>
                        <div>Driver: ₹@(r.DriverAllowancePerDay ?? 0)</div>
                    </td>

                    <!-- ACTION -->
                    <td class="text-end">
                        <div class="d-flex justify-content-end gap-2">
                            <a asp-action="Edit" asp-route-id="@r.Id" class="action-btn btn-edit" title="Edit Rate">
                                <i class="bi bi-pencil-square"></i>
                            </a>

                            <form asp-action="Delete" asp-route-id="@r.Id" method="post" style="display:inline;">
                                <button type="submit" class="action-btn btn-delete"
                                        title="Delete Rate"
                                        onclick="return confirm('Delete rate card @r.Name?')">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
            }

            @if (!Model.Any())
            {
                <tr>
                    <td colspan="8" class="text-center py-5 text-slate-light">
                        <i class="bi bi-cash-stack fs-2 d-block mb-2"></i>
                        No rate cards defined yet.
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
    <script>
        gsap.from("tbody tr", {
            opacity: 0,
            x: -10,
            stagger: 0.05,
            duration: 0.4,
            ease: "power2.out"
        });
    </script>
}
@model SharavaniTours.Models.RateCard
@using SharavaniTours.Models

@{
    ViewData["Title"] = "Edit Pricing Strategy";
}

<style>
    .form-glass-container {
        max-width: 800px;
        margin: 0 auto;
    }

    .section-title {
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        color: #3b82f6;
        margin-bottom: 20px;
        padding-bottom: 5px;
        border-bottom: 1px solid rgba(59, 130, 246, 0.2);
    }

    .form-label {
        color: #94a3b8;
        font-weight: 600;
        font-size: 0.85rem;
        margin-bottom: 8px;
    }

    .form-control-glass {
        background: rgba(15, 23, 42, 0.4) !important;
        border: 1px solid rgba(255, 255, 255, 0.1) !important;
        color: #fff !important;
        padding: 10px 15px;
        border-radius: 10px;
        transition: all 0.3s ease;
    }

        .form-control-glass:focus {
            border-color: #3b82f6 !important;
            box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.15);
            outline: none;
        }

    .btn-save {
        background: #3b82f6;
        color: white;
        border: none;
        padding: 12px 35px;
        border-radius: 10px;
        font-weight: 700;
    }
</style>

<div class="form-glass-container">
    <div class="d-flex align-items-center gap-3 mb-5">
        <div class="icon-box" style="width: 45px; height: 45px; background: rgba(245, 158, 11, 0.1); border-radius: 12px; display: flex; align-items: center; justify-content: center;">
            <i class="bi bi-pencil-square text-warning fs-4"></i>
        </div>
        <div>
            <h2 class="fw-800 mb-0 text-white">Edit Rate Card</h2>
            <p class="text-slate-light mb-0">
                Adjusting pricing for <span class="text-white">@Model.Name</span>
            </p>
        </div>
    </div>

    <form asp-area="Admin" asp-controller="RateCard" asp-action="Edit" method="post">
        <input type="hidden" asp-for="Id" />

        <div class="row g-4">

            <!-- NAME -->
            <div class="col-12">
                <label asp-for="Name" class="form-label"></label>
                <input asp-for="Name" class="form-control-glass w-100" />
            </div>

            <!-- VEHICLE TYPE -->
            <div class="col-md-6">
                <label class="form-label">Vehicle Type</label>
                <select asp-for="VehicleTypeId"
                        asp-items="ViewBag.VehicleTypes"
                        class="form-control-glass w-100">
                </select>
            </div>

            <!-- TRIP TYPE -->
            <div class="col-md-6">
                <label class="form-label">Trip Type</label>
                <select asp-for="TripType" id="tripType" class="form-control-glass w-100">
                    <option value="Local">Local</option>
                    <option value="Outstation">Outstation</option>
                </select>
            </div>

            <!-- 🔹 LOCAL SECTION -->
            <div id="localSection" class="row">
                <div class="col-12 mt-5">
                    <div class="section-title">Standard Base Package</div>
                </div>

                <div class="col-md-4">
                    <label asp-for="BaseKM" class="form-label"></label>
                    <input asp-for="BaseKM" class="form-control-glass w-100" />
                </div>

                <div class="col-md-4">
                    <label asp-for="BaseHours" class="form-label"></label>
                    <input asp-for="BaseHours" class="form-control-glass w-100" />
                </div>

                <div class="col-md-4">
                    <label asp-for="BasePrice" class="form-label"></label>
                    <input asp-for="BasePrice" class="form-control-glass w-100" />
                </div>
            </div>

            <!-- 🔹 OUTSTATION -->
            <div id="outstationSection" class="row">
                <div class="col-12 mt-5">
                    <div class="section-title">Outstation Pricing</div>
                </div>

                <div class="col-md-6">
                    <label asp-for="OutstationPerDayKM" class="form-label"></label>
                    <input asp-for="OutstationPerDayKM" class="form-control-glass w-100" />
                </div>

                <div class="col-md-6">
                    <label asp-for="OutstationRatePerDay" class="form-label"></label>
                    <input asp-for="OutstationRatePerDay" class="form-control-glass w-100" />
                </div>
            </div>

            <!-- 🔹 COMMON (IMPORTANT CHANGE) -->
            <div class="col-12 mt-5">
                <div class="section-title">Additional Charges</div>
            </div>

            <div class="col-md-6">
                <label asp-for="ExtraKMRate" class="form-label"></label>
                <input asp-for="ExtraKMRate" class="form-control-glass w-100" />
            </div>

            <div class="col-md-6">
                <label asp-for="ExtraHourRate" class="form-label"></label>
                <input asp-for="ExtraHourRate" class="form-control-glass w-100" />
            </div>

            <div class="col-md-6">
                <label asp-for="NightCharges" class="form-label"></label>
                <input asp-for="NightCharges" class="form-control-glass w-100" />
            </div>

            <div class="col-md-6">
                <label asp-for="DriverAllowancePerDay" class="form-label"></label>
                <input asp-for="DriverAllowancePerDay" class="form-control-glass w-100" />
            </div>

            <!-- ACTION -->
            <div class="col-12 d-flex justify-content-between mt-5 pt-4">
                <a asp-action="Index" class="text-decoration-none fw-600" style="color:#94a3b8;">
                    Cancel Changes
                </a>

                <button type="submit" class="btn-update">
                    <i class="bi bi-arrow-repeat me-2"></i>Update Rate Card
                </button>
            </div>

        </div>
    </form>
</div>

<script>
    function toggleSections() {
        var type = document.getElementById("tripType").value;

        var local = document.getElementById("localSection");
        var outstation = document.getElementById("outstationSection");

        local.style.display = (type === "Local") ? "flex" : "none";
        outstation.style.display = (type === "Outstation") ? "flex" : "none";

        toggleInputs(local, type !== "Local");
        toggleInputs(outstation, type !== "Outstation");
    }

    function toggleInputs(container, disable) {
        var inputs = container.querySelectorAll("input");

        inputs.forEach(i => {
            i.disabled = disable;
        });
    }

    document.getElementById("tripType").addEventListener("change", toggleSections);

    window.onload = function () {
        toggleSections();
    };
</script>
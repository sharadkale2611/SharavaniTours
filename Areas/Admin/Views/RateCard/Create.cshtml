@model SharavaniTours.Models.RateCard
@using SharavaniTours.Models

@{
    ViewData["Title"] = "Define New Pricing";
}

<style>
    .form-glass-container {
        max-width: 800px;
        margin: 0 auto;
    }

    .section-title {
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        color: #3b82f6;
        margin-bottom: 20px;
        padding-bottom: 5px;
        border-bottom: 1px solid rgba(59, 130, 246, 0.2);
    }

    .form-label {
        color: #94a3b8;
        font-weight: 600;
        font-size: 0.85rem;
        margin-bottom: 8px;
    }

    .form-control-glass {
        background: rgba(15, 23, 42, 0.4) !important;
        border: 1px solid rgba(255, 255, 255, 0.1) !important;
        color: #fff !important;
        padding: 10px 15px;
        border-radius: 10px;
        transition: all 0.3s ease;
    }

        .form-control-glass:focus {
            border-color: #3b82f6 !important;
            box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.15);
            outline: none;
        }

    .btn-save {
        background: #3b82f6;
        color: white;
        border: none;
        padding: 12px 35px;
        border-radius: 10px;
        font-weight: 700;
    }
</style>

<div class="form-glass-container">
    <div class="d-flex align-items-center gap-3 mb-5">
        <div class="icon-box" style="width: 45px; height: 45px; background: rgba(59, 130, 246, 0.1); border-radius: 12px; display: flex; align-items: center; justify-content: center;">
            <i class="bi bi-cash-coin text-primary fs-4"></i>
        </div>
        <div>
            <h2 class="fw-800 mb-0" style="color: #fff;">Create Rate Card</h2>
            <p class="text-slate-light mb-0">Define billing rules for local and outstation trips.</p>
        </div>
    </div>

    <form asp-area="Admin" asp-controller="RateCard" asp-action="Create" method="post">

        <div class="row g-4">

            <!-- 🔹 NAME -->
            <div class="col-12">
                <label asp-for="Name" class="form-label"></label>
                <input asp-for="Name" class="form-control-glass w-100" required />
            </div>

            <!-- VEHICLE Type-->
            <div class="col-md-6">
                <label class="form-label">Vehicle Type</label>
                <select asp-for="VehicleTypeId" class="form-control-glass w-100" asp-items="ViewBag.VehicleTypes">
                    <option value="">Select Vehicle type</option>
                </select>
            </div>

            <!-- 🔹 TRIP TYPE -->
            <div class="col-md-6">
                <label class="form-label">Trip Type</label>
                <select asp-for="TripType" id="tripType" class="form-control-glass w-100">
                    <option value="">Select Trip Type</option>
                    <option value="Local">Local</option>
                    <option value="Outstation">Outstation</option>
                </select>
            </div>


            <!-- 🔹 LOCAL SECTION -->
            <div id="localSection" >
                <div class="row">
                <div class="col-12 mt-5"><div class="section-title">Standard Base Package</div></div>

                <div class="col-md-4">
                    <label asp-for="BaseKM" class="form-label"></label>
                    <input asp-for="BaseKM" class="form-control-glass w-100" />
                </div>

                <div class="col-md-4">
                    <label asp-for="BaseHours" class="form-label"></label>
                    <input asp-for="BaseHours" class="form-control-glass w-100" />
                </div>

                <div class="col-md-4">
                    <label asp-for="BasePrice" class="form-label"></label>
                    <input asp-for="BasePrice" class="form-control-glass w-100" />
                </div>

                @* <div class="col-12 mt-5"><div class="section-title">Extra Charges</div></div> *@

                @* <div class="col-md-6"> *@
                @*     <label asp-for="ExtraKMRate" class="form-label"></label> *@
                @*     <input asp-for="ExtraKMRate" class="form-control-glass w-100" /> *@
                @* </div> *@

                @* <div class="col-md-6"> *@
                @*     <label asp-for="ExtraHourRate" class="form-label"></label> *@
                @*     <input asp-for="ExtraHourRate" class="form-control-glass w-100" /> *@
                @* </div> *@
                </div>
            </div>

            <!-- 🔹 COMMON -->
            <div class="col-12 mt-5"><div class="section-title">Additional Charges</div></div>

            <div class="col-md-6">
                <label asp-for="ExtraKMRate" class="form-label"></label>
                <input asp-for="ExtraKMRate" class="form-control-glass w-100" />
            </div>

            <div class="col-md-6">
                <label asp-for="ExtraHourRate" class="form-label"></label>
                <input asp-for="ExtraHourRate" class="form-control-glass w-100" />
            </div>


            <!-- 🔹 OUTSTATION SECTION -->
            <div id="outstationSection">
                <div class="row">
                    <div class="col-12 mt-5"><div class="section-title">Outstation Pricing</div></div>

                    <div class="col-md-6">
                        <label asp-for="OutstationPerDayKM" class="form-label"></label>
                        <input asp-for="OutstationPerDayKM" class="form-control-glass w-100" />
                    </div>

                    <div class="col-md-6">
                        <label asp-for="OutstationRatePerDay" class="form-label"></label>
                        <input asp-for="OutstationRatePerDay" class="form-control-glass w-100" />
                    </div>
                </div>
            </div>

            <!-- 🔹 COMMON -->
            <div class="col-12 mt-5"><div class="section-title">Additional Charges</div></div>

            <div class="col-md-6">
                <label asp-for="NightCharges" class="form-label"></label>
                <input asp-for="NightCharges" class="form-control-glass w-100" />
            </div>

            <div class="col-md-6">
                <label asp-for="DriverAllowancePerDay" class="form-label"></label>
                <input asp-for="DriverAllowancePerDay" class="form-control-glass w-100" />
            </div>

            <!-- 🔹 SUBMIT -->
            <div class="col-12 d-flex justify-content-between mt-5 pt-4">
                <a asp-action="Index" class="text-decoration-none" style="color:#94a3b8;">
                    Back
                </a>
                <button type="submit" class="btn-save">Save</button>
            </div>

        </div>
    </form>
</div>

<script>
    function toggleSections() {
        var type = document.getElementById("tripType").value;

        var local = document.getElementById("localSection");
        var outstation = document.getElementById("outstationSection");

        local.style.display = (type === "Local") ? "block" : "none";
        outstation.style.display = (type === "Outstation") ? "block" : "none";

        // 🔥 IMPORTANT: disable inputs
        toggleInputs(local, type !== "Local");
        toggleInputs(outstation, type !== "Outstation");
    }

    function toggleInputs(container, disable) {
        var inputs = container.querySelectorAll("input");

        inputs.forEach(i => {
            i.disabled = disable;
        });
    }

    document.getElementById("tripType").addEventListener("change", toggleSections);

    // initial load
    toggleSections();
</script>
@model SharavaniTours.Models.RateCard

@{
    ViewData["Title"] = "Define New Pricing";
}

<style>
    .form-glass-container {
        max-width: 800px;
        margin: 0 auto;
    }

    .section-title {
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        color: #3b82f6;
        margin-bottom: 20px;
        padding-bottom: 5px;
        border-bottom: 1px solid rgba(59, 130, 246, 0.2);
    }

    .form-label {
        color: #94a3b8;
        font-weight: 600;
        font-size: 0.85rem;
        margin-bottom: 8px;
    }

    .form-control-glass {
        background: rgba(15, 23, 42, 0.4) !important;
        border: 1px solid rgba(255, 255, 255, 0.1) !important;
        color: #fff !important;
        padding: 10px 15px;
        border-radius: 10px;
        transition: all 0.3s ease;
    }

        .form-control-glass:focus {
            border-color: #3b82f6 !important;
            box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.15);
            outline: none;
        }

    .input-group-text-glass {
        background: rgba(30, 41, 59, 0.6);
        border: 1px solid rgba(255, 255, 255, 0.1);
        color: #94a3b8;
        border-radius: 10px 0 0 10px;
    }

    .btn-save {
        background: #3b82f6;
        color: white;
        border: none;
        padding: 12px 35px;
        border-radius: 10px;
        font-weight: 700;
        transition: all 0.3s;
        box-shadow: 0 4px 15px rgba(59, 130, 246, 0.3);
    }

        .btn-save:hover {
            background: #2563eb;
            transform: translateY(-2px);
        }
</style>

<div class="form-glass-container">
    <div class="d-flex align-items-center gap-3 mb-5">
        <div class="icon-box" style="width: 45px; height: 45px; background: rgba(59, 130, 246, 0.1); border-radius: 12px; display: flex; align-items: center; justify-content: center;">
            <i class="bi bi-cash-coin text-primary fs-4"></i>
        </div>
        <div>
            <h2 class="fw-800 mb-0" style="color: #fff;">Create Rate Card</h2>
            <p class="text-slate-light mb-0" style="color: #94a3b8 !important;">Define billing rules for local and outstation trips.</p>
        </div>
    </div>

    <form asp-area="Admin" asp-controller="RateCard" asp-action="Create" method="post">
        <div class="row g-4">
            <div class="col-12">
                <label asp-for="Name" class="form-label">Plan Name / Description</label>
                <input asp-for="Name" class="form-control-glass w-100" placeholder="e.g. Corporate Standard - SUV" required />
            </div>

            <div class="col-12 mt-5"><div class="section-title">Standard Base Package</div></div>

            <div class="col-md-4">
                <label asp-for="BaseKM" class="form-label">Base Distance</label>
                <div class="input-group">
                    <input asp-for="BaseKM" class="form-control-glass w-100" placeholder="80" />
                </div>
                <small class="text-muted">Kilometers</small>
            </div>

            <div class="col-md-4">
                <label asp-for="BaseHours" class="form-label">Base Time</label>
                <input asp-for="BaseHours" class="form-control-glass w-100" placeholder="8" />
                <small class="text-muted">Hours</small>
            </div>

            <div class="col-md-4">
                <label asp-for="BasePrice" class="form-label">Package Price</label>
                <input asp-for="BasePrice" class="form-control-glass w-100" placeholder="0.00" />
                <small class="text-muted">INR (₹)</small>
            </div>

            <div class="col-12 mt-5"><div class="section-title">Extra Usage Charges</div></div>

            <div class="col-md-6">
                <label asp-for="ExtraKMRate" class="form-label">Extra KM Rate</label>
                <input asp-for="ExtraKMRate" class="form-control-glass w-100" placeholder="₹ per extra KM" />
            </div>

            <div class="col-md-6">
                <label asp-for="ExtraHourRate" class="form-label">Extra Hour Rate</label>
                <input asp-for="ExtraHourRate" class="form-control-glass w-100" placeholder="₹ per extra Hour" />
            </div>

            <div class="col-12 mt-5"><div class="section-title">Outstation Defaults</div></div>

            <div class="col-md-6">
                <label asp-for="OutstationPerDayKM" class="form-label">Min. Daily KM</label>
                <input asp-for="OutstationPerDayKM" class="form-control-glass w-100" placeholder="300" />
            </div>

            <div class="col-md-6">
                <label asp-for="OutstationRatePerDay" class="form-for">Outstation Rate</label>
                <input asp-for="OutstationRatePerDay" class="form-control-glass w-100" placeholder="₹ per KM" />
            </div>

            <div class="col-12 d-flex align-items-center justify-content-between mt-5 pt-4">
                <a asp-action="Index" class="text-decoration-none fw-600" style="color: #94a3b8;">
                    <i class="bi bi-arrow-left me-2"></i>Back to Rates
                </a>
                <button type="submit" class="btn-save">
                    <i class="bi bi-shield-check me-2"></i>Save Strategy
                </button>
            </div>
        </div>
    </form>
</div>
@model IEnumerable<SharavaniTours.Models.Client>

@{
    ViewData["Title"] = "Client Directory";
}

<style>
    /* Table specific enhancements for dark theme */
    .table-glass {
        color: #e2e8f0; /* Slate 200 for better readability */
        vertical-align: middle; 
        background: #eeeeee13;
    }

        .table-glass thead th {
            background: linear-gradient(180deg, rgba(30, 41, 59, 0.8) 0%, rgba(15, 23, 42, 0.9) 100%);
            color: #3b82f6; /* Accent blue for headers */
            font-weight: 700;
            text-transform: uppercase;
            font-size: 0.75rem;
            letter-spacing: 1px;
            border-bottom: 2px solid rgba(255, 255, 255, 0.05);
            padding: 15px;
        }

        .table-glass td {
            padding: 16px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
            background: transparent;

        }

        .table-glass tr:hover td {
            background: rgba(255, 255, 255, 0.02);
            color: #fff;
        }

    /* Action Icon Buttons */
    .action-btn {
        width: 32px;
        height: 32px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 8px;
        transition: all 0.2s;
        text-decoration: none !important;
    }

    .btn-edit {
        color: #3b82f6;
        background: rgba(59, 130, 246, 0.1);
    }

        .btn-edit:hover {
            background: #3b82f6;
            color: white;
        }

    .btn-delete {
        color: #ef4444;
        background: rgba(239, 68, 68, 0.1);
    }

        .btn-delete:hover {
            background: #ef4444;
            color: white;
        }

    .client-name-cell {
        font-weight: 600;
        color: #fff !important;
    }

    /* High contrast replacement for muted text */
    .text-slate-light {
        color: #94a3b8 !important;
        ;
        font-size: 0.85rem;
    }
</style>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-800 mb-1" style="color: #fff;">Clients</h2>
        <p class="text-slate-light mb-0">Manage your corporate partners and billing entities.</p>
    </div>
    <a asp-area="Admin" asp-controller="Client" asp-action="Create" class="btn btn-primary px-4 py-2"
       style="background: #3b82f6; border: none; border-radius: 10px; font-weight: 600;">
        <i class="bi bi-plus-lg me-2"></i> Add New Client
    </a>
</div>

<div class="table-responsive">
    <table class="table table-glass">
        <thead>
            <tr>
                <th>Company Name</th>
                <th>GST Number</th>
                <th>Office Address</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var c in Model)
            {
                <tr>
                    <td class="client-name-cell">
                        <i class="bi bi-building me-2 text-primary"></i> @c.Name
                    </td>
                    <td>
                        <span class="badge" style="background: rgba(245, 158, 11, 0.1); color: #f59e0b; border: 1px solid rgba(245, 158, 11, 0.2);">
                            @c.GST
                        </span>
                    </td>
                    <td class="text-slate-light">
                        <i class="bi bi-geo-alt me-1"></i> @c.Address
                    </td>
                    <td class="text-end">
                        <div class="d-flex justify-content-end gap-2">
                            <a asp-action="Edit" asp-route-id="@c.Id" class="action-btn btn-edit" title="Edit Client">
                                <i class="bi bi-pencil-square"></i>
                            </a>
                            <a asp-action="Delete" asp-route-id="@c.Id" class="action-btn btn-delete"
                               title="Delete Client"
                               onclick="return confirm('Are you sure you want to delete @c.Name?')">
                                <i class="bi bi-trash"></i>
                            </a>
                        </div>
                    </td>
                </tr>
            }
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="4" class="text-center py-5 text-slate-light">
                        <i class="bi bi-inbox fs-2 d-block mb-2"></i>
                        No clients found. Click "Add New Client" to get started.
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
    <script>
        // Animate table rows on load
        gsap.from("tbody tr", {
            opacity: 0,
            x: -10,
            stagger: 0.05,
            duration: 0.4,
            ease: "power2.out"
        });
    </script>
}
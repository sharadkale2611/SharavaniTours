@model SharavaniTours.Models.Client

@{
    ViewData["Title"] = "New Client Partnership";
}

<style>
    /* Form Glassmorphism */
    .form-glass-container {
        max-width: 600px;
        margin: 0 auto;
    }

    .form-label {
        color: #94a3b8;
        font-weight: 600;
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 8px;
    }

    .form-control-glass {
        background: rgba(15, 23, 42, 0.4) !important;
        border: 1px solid rgba(255, 255, 255, 0.1) !important;
        color: #fff !important;
        padding: 12px 16px;
        border-radius: 12px;
        transition: all 0.3s ease;
    }

        .form-control-glass:focus {
            background: rgba(15, 23, 42, 0.6) !important;
            border-color: #3b82f6 !important;
            box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.15);
            outline: none;
        }

    .validation-error {
        font-size: 0.75rem;
        color: #ef4444;
        margin-top: 5px;
        display: block;
        font-weight: 500;
    }

    .btn-save {
        background: #3b82f6;
        color: white;
        border: none;
        padding: 12px 30px;
        border-radius: 10px;
        font-weight: 700;
        transition: all 0.3s;
        box-shadow: 0 4px 15px rgba(59, 130, 246, 0.3);
    }

        .btn-save:hover {
            background: #2563eb;
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(59, 130, 246, 0.4);
        }

    .btn-back {
        color: #94a3b8;
        text-decoration: none;
        font-weight: 600;
        transition: color 0.2s;
    }

        .btn-back:hover {
            color: #fff;
        }
</style>

<div class="form-glass-container">
    <div class="d-flex align-items-center gap-3 mb-4">
        <div class="icon-box" style="width: 45px; height: 45px; background: rgba(59, 130, 246, 0.1); border-radius: 12px; display: flex; align-items: center; justify-content: center;">
            <i class="bi bi-building-add text-primary fs-4"></i>
        </div>
        <div>
            <h2 class="fw-800 mb-0" style="color: #fff;">Register Client</h2>
            <p class="text-slate-light mb-0" style="color: #94a3b8 !important;">Onboard a new corporate partner to the fleet system.</p>
        </div>
    </div>

    <form asp-area="Admin" asp-controller="Client" asp-action="Create" method="post" class="mt-4">
        @Html.AntiForgeryToken()

        <div class="row g-4">
            <div class="col-12">
                <label asp-for="Name" class="form-label">Client / Company Name</label>
                <input asp-for="Name" class="form-control form-control-glass" placeholder="e.g. Reliance Industries" />
                <span asp-validation-for="Name" class="validation-error"></span>
            </div>

            <div class="col-12">
                <label asp-for="GST" class="form-label">GST Identification Number</label>
                <input asp-for="GST" class="form-control form-control-glass" placeholder="27AAAAA0000A1Z5" />
                <span asp-validation-for="GST" class="validation-error"></span>
            </div>

            <div class="col-12">
                <label asp-for="Address" class="form-label">Office Address</label>
                <textarea asp-for="Address" class="form-control form-control-glass" rows="3" placeholder="Enter complete billing address..."></textarea>
                <span asp-validation-for="Address" class="validation-error"></span>
            </div>

            <div class="col-12 d-flex align-items-center justify-content-between mt-5">
                <a asp-area="Admin" asp-controller="Client" asp-action="Index" class="btn-back">
                    <i class="bi bi-arrow-left me-2"></i> Back to Fleet
                </a>
                <button type="submit" class="btn-save">
                    <i class="bi bi-cloud-check me-2"></i> Save Client
                </button>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        // Subtle entrance for form elements
        gsap.from(".form-glass-container > *", {
            opacity: 0,
            y: 20,
            stagger: 0.1,
            duration: 0.6,
            ease: "power2.out"
        });
    </script>
}
@model SharavaniTours.Models.Vehicle

@{
    ViewData["Title"] = "Add New Fleet Asset";
}

<style>
    .form-glass-container {
        max-width: 600px;
        margin: 0 auto;
    }

    .form-label {
        color: #94a3b8;
        font-weight: 600;
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 8px;
    }

    .form-control-glass {
        background: rgba(15, 23, 42, 0.4) !important;
        border: 1px solid rgba(255, 255, 255, 0.1) !important;
        color: #fff !important;
        padding: 12px 16px;
        border-radius: 12px;
        transition: all 0.3s ease;
    }

        .form-control-glass:focus {
            border-color: #3b82f6 !important;
            box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.15);
            outline: none;
        }

    select.form-control-glass option {
        background: #1e293b;
        color: #fff;
    }

    .btn-save {
        background: #3b82f6;
        color: white;
        border: none;
        padding: 12px 30px;
        border-radius: 10px;
        font-weight: 700;
        transition: all 0.3s;
        box-shadow: 0 4px 15px rgba(59, 130, 246, 0.3);
    }

        .btn-save:hover {
            background: #2563eb;
            transform: translateY(-2px);
        }
</style>

<div class="form-glass-container">
    <div class="d-flex align-items-center gap-3 mb-4">
        <div class="icon-box" style="width: 45px; height: 45px; background: rgba(59, 130, 246, 0.1); border-radius: 12px; display: flex; align-items: center; justify-content: center;">
            <i class="bi bi-car-front text-primary fs-4"></i>
        </div>
        <div>
            <h2 class="fw-800 mb-0" style="color: #fff;">Register Vehicle</h2>
            <p class="text-slate-light mb-0">Add a new car or bus to your active fleet.</p>
        </div>
    </div>

    <form asp-area="Admin" asp-controller="Vehicle" asp-action="Create" method="post" class="mt-4">
        <div class="row g-4">
            <div class="col-12">
                <label asp-for="VehicleNo" class="form-label">Registration Number</label>
                <input asp-for="VehicleNo" class="form-control-glass w-100 text-uppercase" placeholder="e.g. MH 12 AB 1234" />
                <span asp-validation-for="VehicleNo" class="text-danger small"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="VehicleTypeId" class="form-label">Vehicle Type</label>
                <select asp-for="VehicleTypeId" asp-items="ViewBag.VehicleTypes" class="form-control-glass form-select">
                    <option value="">Select Vehicle type</option>
                </select>
                <span asp-validation-for="VehicleTypeId" class="text-danger small"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="DriverId" class="form-label">Primary Driver</label>
                <select asp-for="DriverId" asp-items="ViewBag.DriverList" class="form-control-glass form-select">
                    <option value="">-- Assign Driver --</option>
                </select>
            </div>

            <div class="col-12 d-flex align-items-center justify-content-between mt-5 pt-2">
                <a asp-action="Index" class="text-decoration-none fw-600" style="color: #94a3b8;">Cancel</a>
                <button type="submit" class="btn-save px-4">
                    <i class="bi bi-plus-circle me-2"></i> Save Vehicle
                </button>
            </div>
        </div>
    </form>
</div>
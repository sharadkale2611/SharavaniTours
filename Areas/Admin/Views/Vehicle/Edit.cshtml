@model SharavaniTours.Models.Vehicle

@{
    ViewData["Title"] = "Modify Vehicle Details";
}

<style>
    /* Consistent styles with Create page */
    .form-glass-container {
        max-width: 600px;
        margin: 0 auto;
    }

    .form-label {
        color: #94a3b8;
        font-weight: 600;
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 8px;
    }

    .form-control-glass {
        background: rgba(15, 23, 42, 0.4) !important;
        border: 1px solid rgba(255, 255, 255, 0.1) !important;
        color: #fff !important;
        border-radius: 12px;
        padding: 12px 16px;
    }

    .btn-update {
        background: #f59e0b;
        color: white;
        border: none;
        padding: 12px 30px;
        border-radius: 10px;
        font-weight: 700;
        transition: all 0.3s;
        box-shadow: 0 4px 15px rgba(245, 158, 11, 0.3);
    }

        .btn-update:hover {
            background: #d97706;
            transform: translateY(-2px);
        }
</style>

<div class="form-glass-container">
    <div class="d-flex align-items-center gap-3 mb-4">
        <div class="icon-box" style="width: 45px; height: 45px; background: rgba(245, 158, 11, 0.1); border-radius: 12px; display: flex; align-items: center; justify-content: center;">
            <i class="bi bi-pencil-square text-warning fs-4"></i>
        </div>
        <div>
            <h2 class="fw-800 mb-0" style="color: #fff;">Edit Vehicle</h2>
            <p class="text-slate-light mb-0">Updating asset: <span class="text-white fw-bold">@Model.VehicleNo</span></p>
        </div>
    </div>

    <form asp-area="Admin" asp-controller="Vehicle" asp-action="Edit" method="post" class="mt-4">
        <input type="hidden" asp-for="Id" />

        <div class="row g-4">
            <div class="col-12">
                <label asp-for="VehicleNo" class="form-label">Registration Number</label>
                <input asp-for="VehicleNo" class="form-control-glass w-100 text-uppercase" />
                <span asp-validation-for="VehicleNo" class="text-danger small"></span>
            </div>


            <div class="col-md-6">
                <label asp-for="VehicleTypeId" class="form-label">Vehicle Type</label>
                <select asp-for="VehicleTypeId" asp-items="ViewBag.VehicleTypes" class="form-control-glass form-select">
                    <option value="">Select Vehicle type</option>
                </select>
                <span asp-validation-for="VehicleTypeId" class="text-danger small"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="DriverId" class="form-label">Assigned Driver</label>
                <select asp-for="DriverId" asp-items="ViewBag.DriverList" class="form-control-glass form-select">
                    <option value="">-- Unassigned --</option>
                </select>
                <span asp-validation-for="DriverId" class="text-danger small"></span>
            </div>

            <div class="col-12 d-flex align-items-center justify-content-between mt-5 pt-2">
                <a asp-action="Index" class="text-decoration-none fw-600" style="color: #94a3b8;">Back to Fleet</a>
                <button type="submit" class="btn-update">
                    <i class="bi bi-arrow-repeat me-2"></i> Update Asset
                </button>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
@{
    ViewData["Title"] = "Onboard New Driver";
}

<style>
    .form-glass-container {
        max-width: 600px;
        margin: 0 auto;
    }

    .form-label {
        color: #94a3b8;
        font-weight: 600;
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 8px;
    }

    .input-group-glass {
        background: rgba(15, 23, 42, 0.4);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 12px;
        display: flex;
        align-items: center;
        padding: 0 15px;
        transition: all 0.3s ease;
    }

        .input-group-glass:focus-within {
            border-color: #3b82f6;
            box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.15);
        }

        .input-group-glass i {
            color: #3b82f6;
            font-size: 1.1rem;
            margin-right: 12px;
        }

    .form-control-glass {
        background: transparent !important;
        border: none !important;
        color: #fff !important;
        padding: 12px 0;
        width: 100%;
    }

        .form-control-glass:focus {
            outline: none;
            box-shadow: none;
        }

    .btn-create {
        background: #3b82f6;
        color: white;
        border: none;
        padding: 12px 30px;
        border-radius: 10px;
        font-weight: 700;
        transition: all 0.3s;
        box-shadow: 0 4px 15px rgba(59, 130, 246, 0.3);
    }

        .btn-create:hover {
            background: #2563eb;
            transform: translateY(-2px);
        }
</style>

<div class="form-glass-container">
    <div class="d-flex align-items-center gap-3 mb-4">
        <div class="icon-box" style="width: 45px; height: 45px; background: rgba(59, 130, 246, 0.1); border-radius: 12px; display: flex; align-items: center; justify-content: center;">
            <i class="bi bi-person-badge-fill text-primary fs-4"></i>
        </div>
        <div>
            <h2 class="fw-800 mb-0" style="color: #fff;">Create Driver</h2>
            <p class="text-slate-light mb-0" style="color: #94a3b8 !important;">Register a new driver for fleet assignments.</p>
        </div>
    </div>

    <form asp-area="Admin" asp-controller="Driver" asp-action="Create" method="post" class="mt-4">
        <div class="row g-4">
            <div class="col-12">
                <label class="form-label">Full Name</label>
                <div class="input-group-glass">
                    <i class="bi bi-person"></i>
                    <input name="fullName" class="form-control-glass" placeholder="e.g. Rajesh Kumar" required />
                </div>
            </div>

            <div class="col-12">
                <label class="form-label">Email Address</label>
                <div class="input-group-glass">
                    <i class="bi bi-envelope"></i>
                    <input name="email" type="email" class="form-control-glass" placeholder="driver@sharavanitours.com" required />
                </div>
            </div>

            <div class="col-12">
                <label class="form-label">Portal Password</label>
                <div class="input-group-glass">
                    <i class="bi bi-shield-lock"></i>
                    <input name="password" type="password" class="form-control-glass" placeholder="••••••••" required />
                </div>
                <small class="text-slate-light opacity-50 mt-2 d-block">This password will be used by the driver to log in.</small>
            </div>

            <div class="col-12 d-flex align-items-center justify-content-between mt-5">
                <a asp-action="Index" class="text-decoration-none fw-600" style="color: #94a3b8;">Back to Fleet</a>
                <button type="submit" class="btn-create">
                    <i class="bi bi-person-plus me-2"></i> Register Driver
                </button>
            </div>
        </div>
    </form>
</div>
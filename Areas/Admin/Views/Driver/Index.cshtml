@model IEnumerable<SharavaniTours.Models.ApplicationUser>

@{
    ViewData["Title"] = "Driver Fleet";
}

<style>
    /* Consistent Table Styling */
    .table-glass {
        color: #e2e8f0;
        vertical-align: middle;
        background: rgba(238, 238, 238, 0.07);
    }

        .table-glass thead th {
            background: linear-gradient(180deg, rgba(30, 41, 59, 0.8) 0%, rgba(15, 23, 42, 0.9) 100%);
            color: #3b82f6;
            font-weight: 700;
            text-transform: uppercase;
            font-size: 0.75rem;
            letter-spacing: 1px;
            border-bottom: 2px solid rgba(255, 255, 255, 0.05);
            padding: 15px;
        }

        .table-glass td {
            padding: 16px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
            background: transparent;
        }

        .table-glass tr:hover td {
            background: rgba(255, 255, 255, 0.02);
            color: #fff;
        }

    /* Action Icon Buttons */
    .action-btn {
        width: 32px;
        height: 32px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 8px;
        transition: all 0.2s;
        text-decoration: none !important;
        border: none;
    }

    .btn-view {
        color: #10b981;
        background: rgba(16, 185, 129, 0.1);
    }

        .btn-view:hover {
            background: #10b981;
            color: white;
        }

    .btn-edit {
        color: #3b82f6;
        background: rgba(59, 130, 246, 0.1);
    }

        .btn-edit:hover {
            background: #3b82f6;
            color: white;
        }

    .btn-delete {
        color: #ef4444;
        background: rgba(239, 68, 68, 0.1);
    }

        .btn-delete:hover {
            background: #ef4444;
            color: white;
        }

    .driver-name-cell {
        font-weight: 600;
        color: #fff !important;
    }

    .text-slate-light {
        color: #94a3b8 !important;
        font-size: 0.85rem;
    }
</style>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-800 mb-1" style="color: #fff;">Drivers</h2>
        <p class="text-slate-light mb-0">Manage your active fleet drivers and their access credentials.</p>
    </div>
    <a asp-action="Create" class="btn btn-primary px-4 py-2"
       style="background: #3b82f6; border: none; border-radius: 10px; font-weight: 600;">
        <i class="bi bi-person-badge me-2"></i> Add New Driver
    </a>
</div>

<div class="table-responsive">
    <table class="table table-glass">
        <thead>
            <tr>
                <th>Full Name</th>
                <th>Email Address</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var d in Model)
            {
                <tr>
                    <td class="driver-name-cell">
                        <i class="bi bi-person-circle me-2 text-primary"></i> @d.FullName
                    </td>
                    <td class="text-slate-light">
                        <i class="bi bi-envelope me-1"></i> @d.Email
                    </td>
                    <td class="text-end">
                        <div class="d-flex justify-content-end gap-2">
                            <a asp-action="Details" asp-route-id="@d.Id" class="action-btn btn-view" title="View Details">
                                <i class="bi bi-eye"></i>
                            </a>

                            <a asp-action="Edit" asp-route-id="@d.Id" class="action-btn btn-edit" title="Edit Driver">
                                <i class="bi bi-pencil-square"></i>
                            </a>

                            <form asp-action="Delete" asp-route-id="@d.Id" method="post" style="display:inline;">
                                <button type="submit" class="action-btn btn-delete"
                                        title="Delete Driver"
                                        onclick="return confirm('Are you sure you want to delete @d.FullName?')">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="3" class="text-center py-5 text-slate-light">
                        <i class="bi bi-person-x fs-2 d-block mb-2"></i>
                        No drivers currently registered in the fleet.
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
    <script>
        // Entrance animation for table consistency
        gsap.from("tbody tr", {
            opacity: 0,
            x: -10,
            stagger: 0.05,
            duration: 0.4,
            ease: "power2.out"
        });
    </script>
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - SharavaniTours</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700;800&display=swap" rel="stylesheet">

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Outfit', sans-serif;
            background: linear-gradient(135deg, #0f172a 0%, #1e293b 50%, #334155 100%);
            min-height: 100vh;
            overflow-x: hidden;
        }

        /* FIX: Ensure background is behind everything */
        .bg-decoration {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            z-index: -1;
            overflow: hidden;
        }

        .route-container {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            opacity: 0.4;
        }

        .cab-icon {
            fill: #f59e0b;
            filter: drop-shadow(0 0 8px rgba(245, 158, 11, 0.6));
        }

        .floating-shape {
            position: absolute;
            border-radius: 50%;
            filter: blur(60px);
            opacity: 0.12;
        }

        .shape-1 {
            width: 500px;
            height: 500px;
            background: linear-gradient(135deg, #3b82f6, #8b5cf6);
            top: -100px;
            right: -100px;
        }

        .shape-2 {
            width: 400px;
            height: 400px;
            background: linear-gradient(135deg, #06b6d4, #10b981);
            bottom: -100px;
            left: -100px;
        }

        .shape-3 {
            width: 300px;
            height: 300px;
            background: linear-gradient(135deg, #f59e0b, #ef4444);
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
        }

        /* Navbar FIX */
        .navbar {
            background: rgba(15, 23, 42, 0.85) !important;
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border-bottom: 1px solid rgba(255, 255, 255, 0.08);
            z-index: 1050; /* Above Bootstrap defaults */
        }

        .navbar-brand {
            font-size: 1.6rem;
            font-weight: 800;
            background: linear-gradient(135deg, #f8fafc, #94a3b8);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        /* Mobile Menu Fix */
        @@media (max-width: 991px) {
            .navbar-collapse {
                background: #1e293b;
                padding: 1rem;
                border-radius: 12px;
                margin-top: 1rem;
                border: 1px solid rgba(255,255,255,0.1);
            }
        }

        .content-wrapper {
            width: 100%;
            max-width: 1200px;
            margin: 0 auto;
        }

        .glass-card {
            background: rgba(30, 41, 59, 0.4);
            backdrop-filter: blur(24px);
            border-radius: 24px;
            border: 1px solid rgba(255, 255, 255, 0.08);
            padding: 3rem 2.5rem;
        }

        .loading-screen {
            position: fixed;
            inset: 0;
            background: #0f172a;
            z-index: 9999;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-direction: column;
        }
    </style>
</head>

<body>
    <div class="loading-screen" id="loadingScreen">
        <div class="loading-logo" id="loadingCab" style="font-size:3rem">🚕</div>
        <div class="loading-text" style="color:white; letter-spacing:2px">SHARAVANITOURS</div>
    </div>

    <div class="bg-decoration">
        <div class="floating-shape shape-1"></div>
        <div class="floating-shape shape-2"></div>
        <div class="floating-shape shape-3"></div>
        <svg class="route-container" viewBox="0 0 1920 1080" preserveAspectRatio="xMidYMid slice">
            <path id="routePath" d="M -100,800 C 400,800 500,300 960,540 C 1420,780 1600,200 2100,400" fill="none" stroke="rgba(255,255,255,0.15)" stroke-width="3" stroke-dasharray="12, 12" />
            <g id="animatedCab" transform="translate(-25, -15)">
                <path class="cab-icon" d="M38.5,12.5 h-3 v-2 c0-2.2-1.8-4-4-4 h-13 c-2.2,0-4,1.8-4,4 v2 h-3 c-1.4,0-2.5,1.1-2.5,2.5 v7 c0,1.4,1.1,2.5,2.5,2.5 h1.2 l1.8,11.5 c0.2,1.4,1.4,2.5,2.9,2.5 h15 c1.4,0,2.6-1.1,2.9-2.5 l1.8-11.5 h1.2 c1.4,0,2.5-1.1,2.5-2.5 v-7 C41,13.6,39.9,12.5,38.5,12.5z M18.5,10.5 c0-1.1,0.9-2,2-2 h9 c1.1,0,2,0.9,2,2 v2 h-13 V10.5z M32.5,33.5 h-15 c-0.4,0-0.7-0.3-0.8-0.6 l-1.4-9.4 h19.3 l-1.4,9.4 C33.2,33.2,32.9,33.5,32.5,33.5z" />
            </g>
        </svg>
    </div>

    <nav class="navbar navbar-expand-lg navbar-dark fixed-top" id="mainNavbar">
        <div class="container">
            <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                @* <span class="brand-icon">🚕</span> *@
                <img src="~/logo.png" style="width:80px" /> SharavaniTours
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarToggler">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarToggler">
                <div class="ms-auto d-flex flex-column flex-lg-row gap-3 mt-3 mt-lg-0" id="navButtons">
                    <a class="btn btn-outline-light btn-sm px-4" asp-area="Identity" asp-page="/Account/Login">Sign In</a>
                    @* <a class="btn btn-primary btn-sm px-4 text-white" style="background:#3b82f6; border:none" asp-area="Identity" asp-page="/Account/Register">Book Now</a> *@
                </div>
            </div>
        </div>
    </nav>

    <div class="main-content" style="padding-top: 100px;">
        <div class="">
            @if (ViewData["Title"]?.ToString() == "Premium Travel Solutions")
            {
                @RenderBody()
            }
            else
            {
                <div class="glass-card" id="mainCard">
                    @RenderBody()
                </div>
            }
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/MotionPathPlugin.min.js"></script>

    <script>
        gsap.registerPlugin(MotionPathPlugin);

        function animateCabPath() {
            gsap.to("#animatedCab", {
                duration: 25, repeat: -1, ease: "none",
                motionPath: { path: "#routePath", align: "#routePath", autoRotate: 90, alignOrigin: [0.5, 0.5] }
            });
        }

        window.addEventListener('load', () => {
            const tl = gsap.timeline();

            // Fade out loader
            tl.to('#loadingScreen', { opacity: 0, duration: 0.5, onComplete: () => document.getElementById('loadingScreen').remove() });

            // Slide in Navbar
            tl.from('#mainNavbar', { y: -50, opacity: 0, duration: 0.8, ease: "power3.out" });

            // Stagger buttons - selector adjusted to handle the collapse container
            tl.from('#navButtons a', { x: 20, opacity: 0, duration: 0.5, stagger: 0.1 }, "-=0.4");

            // Card Reveal
            tl.from('#mainCard', { scale: 0.9, opacity: 0, y: 40, duration: 1, ease: "power3.out" }, "-=0.5");

            animateCabPath();
            gsap.to('.shape-1', { x: 40, y: 30, duration: 10, repeat: -1, yoyo: true, ease: "sine.inOut" });
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
@using Microsoft.AspNetCore.Identity
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SharavaniTours Admin</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700;800&display=swap" rel="stylesheet">

    <style>
        :root {
            --sidebar-width: 280px;
            --accent-blue: #3b82f6;
            --accent-amber: #f59e0b;
            --text-muted: #94a3b8;
        }

        body {
            font-family: 'Outfit', sans-serif;
            background: linear-gradient(135deg, #0f172a 0%, #1e293b 50%, #0f172a 100%);
            background-attachment: fixed;
            color: #f8fafc;
            min-height: 100vh;
            margin: 0;
            overflow-x: hidden;
        }

        /* Sidebar Glassmorphism */
        .sidebar {
            width: var(--sidebar-width);
            height: 100vh;
            position: fixed;
            background: rgba(15, 23, 42, 0.95);
            backdrop-filter: blur(20px);
            border-right: 1px solid rgba(255, 255, 255, 0.08);
            z-index: 1050;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            left: 0;
        }

        .sidebar-header {
            padding: 25px 20px;
            border-bottom: 1px solid rgba(255,255,255,0.05);
        }

        .sidebar-brand {
            font-weight: 800;
            font-size: 1.4rem;
            background: linear-gradient(135deg, #fff, #94a3b8);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            text-decoration: none;
            display: block;
        }

        /* Sidebar Group Titles Fix */
        .menu-group-title {
            padding: 25px 25px 10px;
            font-size: 0.7rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            color: var(--accent-amber); /* Amber for high visibility */
            opacity: 0.9;
        }

        .sidebar a {
            color: var(--text-muted);
            padding: 12px 25px;
            display: flex;
            align-items: center;
            gap: 12px;
            text-decoration: none;
            transition: all 0.2s;
            font-weight: 400;
        }

            .sidebar a i {
                font-size: 1.2rem;
                transition: transform 0.2s;
            }

            .sidebar a:hover {
                background: rgba(255, 255, 255, 0.03);
                color: #fff;
            }

                .sidebar a:hover i {
                    transform: translateX(3px);
                    color: var(--accent-blue);
                }

            .sidebar a.active {
                background: linear-gradient(90deg, rgba(59, 130, 246, 0.15) 0%, transparent 100%);
                color: #fff;
                border-left: 4px solid var(--accent-blue);
                font-weight: 600;
            }

        /* Topbar & Login Fixes */
        .topbar {
            height: 70px;
            background: rgba(15, 23, 42, 0.7);
            backdrop-filter: blur(15px);
            border-bottom: 1px solid rgba(255, 255, 255, 0.08);
            margin-left: var(--sidebar-width);
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 30px;
            position: sticky;
            top: 0;
            z-index: 1000;
        }

            /* Force Login Partial to one line and visible color */
            .topbar .navbar-nav {
                flex-direction: row !important;
                gap: 20px;
                align-items: center;
            }

            .topbar .nav-link, .topbar .btn-link {
                color: #fff !important;
                font-weight: 600;
                text-decoration: none;
                font-size: 0.9rem;
                border: none;
                background: none;
                padding: 0;
            }

                .topbar .nav-link:hover {
                    color: var(--accent-blue) !important;
                }

        /* Content Area */
        .content {
            margin-left: var(--sidebar-width);
            padding: 40px;
            transition: margin 0.3s ease;
        }

        .admin-card {
            background: rgba(30, 41, 59, 0.4);
            backdrop-filter: blur(20px);
            border-radius: 20px;
            border: 1px solid rgba(255, 255, 255, 0.08);
            padding: 30px;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
        }

        /* Mobile Overlay */
        #sidebarOverlay {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(0, 0, 0, 0.6);
            backdrop-filter: blur(4px);
            z-index: 1040;
        }

        /* Mobile adjustments */
        @@media (max-width: 992px) {
            .sidebar {
                left: -280px;
            }

                .sidebar.active {
                    left: 0;
                }

            .topbar, .content {
                margin-left: 0;
            }

            #sidebarOverlay.active {
                display: block;
            }
        }
    </style>
</head>

<body>
    <div id="sidebarOverlay" onclick="toggleSidebar()"></div>

    <div class="sidebar" id="sidebar">
        <div class="sidebar-header d-flex justify-content-between align-items-center">
            <a class="sidebar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                🚕 SharavaniTours
            </a>
            <button class="btn btn-link text-white d-lg-none p-0" onclick="toggleSidebar()">
                <i class="bi bi-x-lg fs-4"></i>
            </button>
        </div>

        <div class="mt-2">
            <a asp-area="" asp-controller="Home" asp-action="Index">
                <i class="bi bi-speedometer2"></i> Dashboard
            </a>

            @if (User.IsInRole("Admin"))
            {
                <div class="menu-group-title">Organization</div>
                <a asp-area="Admin" asp-controller="Client" asp-action="Index">
                    <i class="bi bi-building"></i> Clients
                </a>
                <a asp-area="Admin" asp-controller="ClientUser" asp-action="Index">
                    <i class="bi bi-people"></i> Client Users
                </a>

                <div class="menu-group-title">Fleet Operations</div>
                <a asp-area="Admin" asp-controller="Driver" asp-action="Index">
                    <i class="bi bi-person-badge"></i> Drivers
                </a>
                <a asp-area="Admin" asp-controller="Vehicle" asp-action="Index">
                    <i class="bi bi-car-front"></i> Vehicles
                </a>
                <a asp-area="Admin" asp-controller="Trip" asp-action="Index">
                    <i class="bi bi-map"></i> All Trips
                </a>
                <a asp-area="Admin" asp-controller="RateCard" asp-action="Index">
                    <i class="bi bi-cash-stack"></i> Pricing Cards
                </a>
                <a asp-area="Driver" asp-controller="Driver" asp-action="InvoiceReport">
                    <i class="border-info"></i> Invoice Reports
                </a>
            }

            @if (User.IsInRole("Driver"))
            {
                <div class="menu-group-title">Driver Portal</div>
                <a asp-area="Driver" asp-controller="Driver" asp-action="MyTrips">
                    <i class="bi bi-calendar-check"></i> My Schedule
                </a>
            }
        </div>
    </div>

    <div class="topbar">
        <div class="d-flex align-items-center gap-3">
            <button class="btn btn-link text-white d-lg-none p-0" onclick="toggleSidebar()">
                <i class="bi bi-list fs-3"></i>
            </button>
            <h5 class="mb-0 fw-bold d-none d-md-block">@ViewData["Title"]</h5>
        </div>

        <div class="login-container">
            <partial name="_LoginPartial" />
        </div>
    </div>

    <div class="content">
        <div class="admin-card" style="min-height:75vh">
            @RenderBody()
        </div>

        <footer class="text-center  mt-5 pb-4" style="color:#aabbe0">
            <small>&copy; 2026 SharavaniTours • System Version 2.1.0</small>
        </footer>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>

    <script>
        function toggleSidebar() {
            document.getElementById("sidebar").classList.toggle("active");
            document.getElementById("sidebarOverlay").classList.toggle("active");
        }

        // Active Link Highlighting logic
        document.addEventListener("DOMContentLoaded", () => {
            const currentPath = window.location.pathname;
            document.querySelectorAll('.sidebar a').forEach(link => {
                const linkPath = link.getAttribute('href');
                if (currentPath === linkPath || (currentPath.includes(linkPath) && linkPath !== "/")) {
                    link.classList.add('active');
                }
            });

            // Gentle entry animation for the main card
            gsap.from(".admin-card", {
                opacity: 0,
                y: 15,
                duration: 0.5,
                ease: "power2.out"
            });
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>